---
import { marked } from 'marked';

interface Props {
  content: string;
}

const { content } = Astro.props;
const html = marked.parse(content, { async: false });
---

<div
  class="platform-markdown text-utility-2 [&_h1]:mt-10 [&_h1]:font-serif [&_h1]:text-3xl [&_h1]:font-extralight [&_h1]:leading-tight [&_h1]:text-brand-white [&_h2]:mt-9 [&_h2]:font-serif [&_h2]:text-2xl [&_h2]:font-extralight [&_h2]:leading-tight [&_h2]:text-brand-white [&_h3]:mt-7 [&_h3]:font-serif [&_h3]:text-xl [&_h3]:font-normal [&_h3]:text-brand-white [&_hr]:my-8 [&_hr]:border-secondary-2/30 [&_li]:ml-5 [&_li]:list-disc [&_li]:leading-relaxed [&_p]:mt-4 [&_p]:leading-relaxed [&_strong]:font-medium [&_strong]:text-brand-white [&_table]:mt-6 [&_table]:w-full [&_table]:border-collapse [&_td]:border [&_td]:border-secondary-2/30 [&_td]:px-3 [&_td]:py-2 [&_th]:border [&_th]:border-secondary-2/40 [&_th]:bg-secondary-4/35 [&_th]:px-3 [&_th]:py-2 [&_th]:text-left [&_th]:font-normal [&_th]:text-brand-white [&_ul]:mt-4 [&_ul]:space-y-2"
>
  <Fragment set:html={html} />
</div>
