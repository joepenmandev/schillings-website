---
interface Props {
  limits: readonly string[];
}

const { limits } = Astro.props;
---

<section class="platform-card mt-6 rounded-xl p-5" data-platform-refusal-panel>
  <h2 class="font-serif text-xl text-brand-white">Refusal and limits</h2>
  <ul class="mt-3 space-y-2 text-sm text-utility-2">
    {limits.map((limit) => <li>• {limit}</li>)}
  </ul>
</section>
