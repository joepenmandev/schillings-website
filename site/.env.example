# --- Contact form (`QualifyingForm` → `api/contact.ts`) ---
# Dev: leave PUBLIC_FORM_ENDPOINT empty — the form logs the JSON payload to the browser console instead of POSTing.
# Production (Vercel): set both in the project (never commit real URLs to git):
#   PUBLIC_FORM_ENDPOINT=/api/contact
#   CONTACT_WEBHOOK_URL=https://hooks.zapier.com/...   (or Make.com — server-side only, not exposed to the client)
PUBLIC_FORM_ENDPOINT=
# CONTACT_WEBHOOK_URL=

# --- Optional: global rate limit for `/api/contact` (Upstash Redis, Edge-safe) ---
# If both are set, limits apply across all isolates (see `api/contact.ts`). Omit to use in-memory only.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Optional override (default 30): max POSTs per IP per minute for both paths
# CONTACT_RATE_LIMIT_MAX=30

# --- Optional local integration test ---
# Uncomment to POST to your webhook from `npm run dev` (do not commit secrets):
# PUBLIC_FORM_ENDPOINT=/api/contact
# CONTACT_WEBHOOK_URL=https://hooks.zapier.com/...

# --- Site URL (canonical, sitemap, RSS) ---
# Optional override for `astro.config.ts` `site`. If unset, Vercel builds use https://$VERCEL_URL; local dev defaults to http://localhost:4321.
# PUBLIC_SITE_URL=https://your-public-site.example

# --- Legacy migration scripts (`import:news`, `import:people`) ---
# Origin of the HTML source to fetch (no trailing slash). Defaults to https://example.com if unset (won’t fetch real pages until set).
# LEGACY_SITE_ORIGIN=https://legacy-source.example

# --- Optional: production HTTP Basic Auth gate ---
# When both are set on a production deployment, Astro pages require browser login (`src/middleware.ts`).
# `api/contact.ts` also checks these (Vercel API routes do not run Astro middleware).
# Leave unset to disable auth gate.
# SITE_USER=reviewer
# SITE_PASS=use-a-long-random-password
#
# Temporary: set to 1 or true to skip Basic Auth on this deployment (e.g. open staging for ~5 minutes for a
# review tool). Remove right after — do not leave on production.
# DISABLE_SITE_BASIC_AUTH=
#
# Optional: comma-separated hostnames that require Basic Auth when SITE_USER/SITE_PASS are set.
# If unset, every host is gated. Example: gate only the live domain so *.vercel.app previews stay open:
# BASIC_AUTH_HOSTS=www.example.com,example.com
