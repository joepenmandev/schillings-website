# --- Contact form (`QualifyingForm` → `api/contact.ts`) ---
# Dev: leave PUBLIC_FORM_ENDPOINT empty — the form logs the JSON payload to the browser console instead of POSTing.
# Production (Vercel): set both in the project (never commit real URLs to git):
#   PUBLIC_FORM_ENDPOINT=/api/contact
#   CONTACT_WEBHOOK_URL=https://hooks.zapier.com/...   (or Make.com — server-side only, not exposed to the client)
PUBLIC_FORM_ENDPOINT=
# CONTACT_WEBHOOK_URL=

# --- Optional: global rate limit for `/api/contact` (Upstash Redis, Edge-safe) ---
# If both are set, limits apply across all isolates (see `api/contact.ts`). Omit to use in-memory only.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Optional override (default 30): max POSTs per IP per minute for both paths
# CONTACT_RATE_LIMIT_MAX=30

# --- Optional local integration test ---
# Uncomment to POST to your webhook from `npm run dev` (do not commit secrets):
# PUBLIC_FORM_ENDPOINT=/api/contact
# CONTACT_WEBHOOK_URL=https://hooks.zapier.com/...
