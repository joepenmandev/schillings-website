---
import Base from '@/layouts/Base.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import DocumentMain from '@/components/DocumentMain.astro';
import HtmlSitemapContent from '@/components/HtmlSitemapContent.astro';
import { buildJsonLdGraph, buildPageEntityJsonLd } from '@/lib/jsonld-page';

const locale = 'en-us';
const origin = Astro.site?.origin ?? Astro.url.origin;
const description = 'Overview of main pages on the United States Schillings site.';
const jsonLd = buildJsonLdGraph(
  buildPageEntityJsonLd({
    origin,
    locale,
    pathSegment: 'sitemap',
    pageType: 'WebPage',
    name: 'Sitemap | Schillings',
    description,
  }),
);
---

<Base title="Sitemap | Schillings" {description} {locale} pathAfterLocale="sitemap">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <SiteHeader {locale} />
  <DocumentMain contentWidth="wide">
    <HtmlSitemapContent {locale} />
  </DocumentMain>
</Base>
