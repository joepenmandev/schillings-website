---
import Base from '@/layouts/Base.astro';
import MarketingStubNav from '@/components/MarketingStubNav.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import DocumentMain from '@/components/DocumentMain.astro';
import StrategicBreadcrumb from '@/components/StrategicBreadcrumb.astro';
import PeopleDirectory from '@/components/PeopleDirectory.astro';
import { localeHref } from '@/lib/site-nav';
import { PEOPLE_DIRECTORY_H1_CLASS } from '@/lib/visual-tokens';
import { publishedPeople } from '@/data/people';
import { peopleDirectoryMeta } from '@/lib/locale-marketing-meta';
import { buildPeopleDirectoryGraphJsonLd } from '@/lib/jsonld-page';
import { locales, isLocale } from '@/i18n/config';

const locale = 'en-us';
const origin = Astro.site?.origin ?? Astro.url.origin;
const { title: peoplePageTitle, description: peoplePageDescription } = peopleDirectoryMeta(locale);
const peopleJsonLd = buildPeopleDirectoryGraphJsonLd({
  origin,
  locale,
  people: publishedPeople().map((p) => ({ slug: p.slug, name: p.name })),
  pageTitle: peoplePageTitle,
  pageDescription: peoplePageDescription,
});
---

<Base
  title={peoplePageTitle}
  description={peoplePageDescription}
  {locale}
  pathAfterLocale="people"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(peopleJsonLd)} />
  <SiteHeader {locale} />
  <DocumentMain contentWidth="wide">
    <StrategicBreadcrumb
      items={[
        { label: 'Home', href: localeHref(locale, '') },
        { label: 'People' },
      ]}
    />
    <h1 class:list={['mt-6 md:mt-8', PEOPLE_DIRECTORY_H1_CLASS]}>
      People
    </h1>
    <p class="mt-4 max-w-3xl text-pretty text-base leading-relaxed text-secondary-3">
      Browse partners and teams. Use the filters below to narrow by practice area, expertise, and location.
    </p>
    <p class="mt-3 max-w-3xl text-pretty text-sm leading-relaxed text-secondary-3 md:text-base">
      Fuller biographies link to practice hubs, typical situations that sit alongside those areas, and published Intelligence
      where a colleague is credited.
    </p>
    <PeopleDirectory {locale} />
    <MarketingStubNav {locale} currentSegment="people" />
  </DocumentMain>
</Base>
