---
import Base from '@/layouts/Base.astro';
import HomePageMain from '@/components/HomePageMain.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import { homePageMeta } from '@/lib/locale-marketing-meta';
import { buildJsonLdGraph, buildPageEntityJsonLd } from '@/lib/jsonld-page';

const locale = 'en-us';

const origin = Astro.site?.origin ?? Astro.url.origin;
const { title: homeTitle, description: homeDescription } = homePageMeta(locale);
const homeWebPageJsonLd = buildJsonLdGraph(
  buildPageEntityJsonLd({
    origin,
    locale,
    pathSegment: '',
    pageType: 'WebPage',
    name: homeTitle,
    description: homeDescription,
  }),
);
---

<Base title={homeTitle} description={homeDescription} {locale} pathAfterLocale="">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(homeWebPageJsonLd)} />
  <SiteHeader {locale} />
  <main id="main">
    <HomePageMain {locale} />
  </main>
</Base>
