---
import Base from '@/layouts/Base.astro';
import MarketingStubNav from '@/components/MarketingStubNav.astro';
import NewsArchiveFeaturedHero from '@/components/NewsArchiveFeaturedHero.astro';
import NewsArchiveIndexHero from '@/components/NewsArchiveIndexHero.astro';
import NewsArticleList from '@/components/NewsArticleList.astro';
import NewsPaginationNav from '@/components/NewsPaginationNav.astro';
import NewsTopicStrip from '@/components/NewsTopicStrip.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import DocumentMain from '@/components/DocumentMain.astro';
import { breadcrumbListGraphNode } from '@/lib/jsonld-breadcrumbs';
import { buildJsonLdGraph, buildNewsIndexGraphJsonLd } from '@/lib/jsonld-page';
import { absolutePageUrl } from '@/lib/public-url';
import { articlesForNewsPage, newsTotalPages } from '@/lib/news-pagination';
import { localeHref } from '@/lib/site-nav';

const locale = 'en-us';
const page = 1;
const articles = articlesForNewsPage(page);
const featuredArticle = articles[0];
const gridArticles = featuredArticle ? articles.slice(1) : [];
const totalPages = newsTotalPages();
const origin = (Astro.site ?? new URL('https://schillingspartners.com')).href.replace(/\/$/, '');
const nextHref = totalPages > 1 ? `${absolutePageUrl(origin, locale, 'news/page/2')}` : null;

const newsTitle = 'News & Insights | Schillings';
const newsDescription =
  'News, views, and analysis from Schillings on reputation, privacy, litigation, and high-stakes matters.';
const newsGraph = buildNewsIndexGraphJsonLd({
  origin,
  locale,
  articles: articles.map((a) => ({ slug: a.slug, title: a.title })),
  pageTitle: newsTitle,
  pageDescription: newsDescription,
}) as { '@graph': Record<string, unknown>[] };
const newsJsonLd = buildJsonLdGraph(
  ...newsGraph['@graph'],
  breadcrumbListGraphNode([
    { name: 'Home', item: `${absolutePageUrl(origin, locale, '')}` },
    { name: 'News & Insights', item: `${absolutePageUrl(origin, locale, 'news')}` },
  ]),
);
---

<Base
  title={newsTitle}
  description={newsDescription}
  {locale}
  pathAfterLocale="news"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(newsJsonLd)} />
  {nextHref && <link slot="head" rel="next" href={nextHref} />}
  <link
    slot="head"
    rel="alternate"
    type="application/rss+xml"
    title={`Schillings News (${locale})`}
    href={localeHref(locale, 'news/rss.xml')}
  />
  <SiteHeader {locale} />
  <NewsArchiveIndexHero {locale} />
  <DocumentMain contentWidth="wide">
    <section class="rounded-lg border border-secondary-2/30 bg-utility-2/40 px-5 py-5 md:px-6">
      <h2 class="font-serif text-xl font-normal tracking-tight text-secondary-4 md:text-2xl">
        Schillings Intelligence
      </h2>
      <p class="mt-3 max-w-4xl text-pretty text-sm leading-relaxed text-secondary-3 md:text-base">
        Use the Executive Intelligence Platform for structured exposure, narrative, and crisis assessments linked to
        methodology pages and confidence disclosures.
      </p>
      <a
        href="/executive-intelligence-platform/"
        class="mt-4 inline-flex rounded-sm border border-secondary-3 px-4 py-2 text-sm text-secondary-4 transition-colors hover:bg-utility-2/60 focus-visible:outline focus-visible:outline-2 focus-visible:outline-secondary-4"
      >
        Explore the platform
      </a>
    </section>
    {featuredArticle ? (
      <div class="mt-8 md:mt-10">
        <NewsArchiveFeaturedHero {locale} article={featuredArticle} showTopicBadges />
      </div>
    ) : null}
    {gridArticles.length > 0 ? (
      <>
        <h2 class="sr-only">More articles</h2>
        <NewsArticleList
          {locale}
          articles={gridArticles}
          showTopicBadges
          class="mt-12 border-t border-secondary-2/30 pt-12"
        />
      </>
    ) : null}
    <NewsTopicStrip {locale} />
    {totalPages > 1 ? <NewsPaginationNav {locale} currentPage={1} {totalPages} /> : null}
    <MarketingStubNav {locale} currentSegment="news" />
  </DocumentMain>
</Base>
