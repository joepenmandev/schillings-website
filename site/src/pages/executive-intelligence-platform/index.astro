---
import Base from '@/layouts/Base.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import DocumentMain from '@/components/DocumentMain.astro';
import IntelligenceReport from '@/components/platform/IntelligenceReport.astro';
import { loadPlatformDoc } from '@/lib/platform-docs';
import { platformAssessments } from '@/data/platform-assessments';
import { linkedInsightsFor } from '@/lib/platform/linking-rules';
import { platformScenarios } from '@/data/platform-scenarios';

const locale = 'en-gb';
const content = loadPlatformDoc('page-copy/hub.md');
---

<Base
  title="Schillings Intelligence | Executive Intelligence Platform"
  description="Digital Executive Infrastructure for the world's most exposed principals."
  {locale}
  pathAfterLocale="executive-intelligence-platform"
  noindex
>
  <SiteHeader {locale} />
  <DocumentMain contentWidth="wide">
    <IntelligenceReport
      title="Executive Intelligence Platform"
      subtitle="Three pillars. Five named methodologies. One unified Intelligence Report."
      content={content}
      assessment={platformAssessments.default}
      insights={linkedInsightsFor('default')}
      scenarios={platformScenarios}
    />
  </DocumentMain>
</Base>
