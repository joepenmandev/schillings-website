---
import ExpertiseHubDetail from '@/components/ExpertiseHubDetail.astro';
import { EXPERTISE_IDS, type ExpertiseId } from '@/data/people-taxonomy';
import { isExpertiseId } from '@/lib/service-hubs';

export function getStaticPaths() {
  return EXPERTISE_IDS.map((expertiseId) => ({ params: { expertiseId } }));
}

const expertiseIdRaw = Astro.params.expertiseId;
if (typeof expertiseIdRaw !== 'string' || !isExpertiseId(expertiseIdRaw)) {
  return new Response(null, { status: 404 });
}
const locale = 'en-gb';
const expertiseId = expertiseIdRaw as ExpertiseId;
---

<ExpertiseHubDetail {locale} {expertiseId} />
