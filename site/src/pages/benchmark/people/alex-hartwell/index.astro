---
import Base from '@/layouts/Base.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import DocumentMain from '@/components/DocumentMain.astro';
import StrategicBreadcrumb from '@/components/StrategicBreadcrumb.astro';
import { localeHref } from '@/lib/site-nav';

const locale = 'en-gb';

const person = {
  name: 'Alex Hartwell',
  role: 'Partner',
  location: 'London',
  strap: 'Privacy, Reputation & Media',
  imagePath: '/people-photos/placeholder-benchmark-portrait.svg',
};

const opener =
  'Alex Hartwell advises individuals, families and organisations on high-stakes privacy, reputation and media matters where legal, strategic and reputational risks intersect.';

const biographyParagraphs = [
  'Alex leads the firm\'s global entertainment practice and is widely recognised for expertise in complex litigation involving privacy, defamation and media law, often spanning multiple jurisdictions.',
  'Alex represents clients in some of the most sensitive and complex legal disputes, where litigation, reputation and public exposure converge.',
  'Alex\'s work includes defending reputations, managing crisis situations and protecting clients from intrusive media coverage. He regularly advises in urgent applications, cross-border disputes and cases involving parallel proceedings.',
  'Alex works closely with clients, specialist counsel and investigators when risk, source reliability or public exposure may affect litigation outcomes. His practice spans litigation, interim relief, pre-action strategy and post-judgment reputation management.',
];

const recognitions = [
  { title: 'Band 1', source: 'Chambers & Partners 2024' },
  { title: 'Leading Partner', source: 'Legal 500 2024' },
  { title: 'Top Flight', source: "Spears 500 2024" },
  { title: 'Recognised Practitioner', source: "Who's Who Legal 2024" },
];

const expertise = [
  'Privacy & Data Protection',
  'Defamation & Media Law',
  'Reputation Management',
  'Entertainment & Sport',
  'Cross-border Disputes',
  'Crisis Response',
];

const situations = [
  { title: 'Media Exposure & Scrutiny', body: 'Managing public attention and media narratives.' },
  { title: 'Reputation Under Threat', body: 'Protecting reputations and responding to damaging claims.' },
  { title: 'Privacy & Protection', body: 'Safeguarding privacy and sensitive personal information.' },
  { title: 'High-Stakes Litigation', body: 'Handling complex, sensitive and high value disputes.' },
  { title: 'International Disputes', body: 'Cross-border disputes and jurisdictional challenges.' },
  { title: 'Sensitive Investigations', body: 'Supporting internal and external sensitive investigations.' },
  { title: 'Online Harassment & Abuse', body: 'Addressing online harm and digital threats.' },
  { title: 'AI & Emerging Risks', body: 'Advising on AI, data and emerging legal risks.' },
];

const publications = [
  { title: 'The growing intersection of privacy and AI', date: 'May 2024' },
  { title: 'Reputation management in the age of social media', date: '12 March 2024' },
  { title: 'Defamation law reforms: what to watch', date: '9 February 2024' },
];

const memberships = [
  'University of Cambridge (BA), BPP Law School (LPC)',
  'Media and Privacy Law Committee (Chair)',
  'International Bar Association',
  'Law Society of England and Wales',
  'Languages: English',
];
---

<Base
  title="Draft bio template (fictional) | Schillings"
  description="Hidden draft practitioner bio template for staging; fictional data, noindex."
  {locale}
  pathAfterLocale="benchmark/people/alex-hartwell"
  noindex={true}
>
  <SiteHeader {locale} deferHeaderLogoPriority={true} />
  <DocumentMain contentWidth="wide">
    <article>
      <StrategicBreadcrumb
        items={[
          { label: 'Home', href: localeHref(locale, '') },
          { label: 'Draft template' },
          { label: person.name },
        ]}
      />
      <p class="mt-5 max-w-prose text-xs font-normal uppercase tracking-wide text-secondary-2/90 md:mt-6">
        Draft bio template - staging/internal only (fictional profile, noindex)
      </p>

      <section class="mt-5 grid grid-cols-1 gap-7 border-b border-secondary-2/[0.08] pb-12 md:mt-6 md:gap-8 md:pb-16 lg:grid-cols-[1fr_420px] lg:items-start lg:gap-10">
        <div>
          <h1 class="text-4xl font-extralight leading-[1.06] tracking-tight text-secondary-4 sm:text-5xl md:text-6xl">{person.name}</h1>
          <p class="mt-3 text-lg font-light text-secondary-4 md:text-xl">
            {person.role}
            <span class="mx-2 text-secondary-2/80">·</span>
            {person.location}
          </p>
          <p class="mt-1.5 font-serif text-lg font-extralight italic text-secondary-3 md:text-xl">{person.strap}</p>
          <div class="mt-6 h-px w-10 bg-secondary-2/30" />
          <p class="mt-7 max-w-2xl text-pretty text-lg leading-[1.55] text-secondary-4 md:mt-8 md:text-xl md:leading-relaxed">{opener}</p>
          <p class="mt-5 max-w-2xl text-pretty text-sm leading-relaxed text-secondary-3 md:mt-6">
            This benchmark profile mirrors shared styling while testing denser institutional structure and early trust cues.
          </p>
        </div>
        <div class="overflow-hidden bg-utility-2/25 shadow-sm ring-1 ring-secondary-2/10">
          <img
            src={person.imagePath}
            alt={person.name}
            width={840}
            height={560}
            class="h-auto w-full object-cover"
            sizes="(max-width: 1024px) 100vw, 420px"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      </section>

      <section class="mt-10 md:mt-14">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-5 md:gap-0 md:divide-x md:divide-secondary-2/[0.08]">
          <div class="md:col-span-1 md:pr-6 md:pt-0.5">
            <p class="text-[11px] font-medium uppercase tracking-wider text-secondary-2/85">Recognised by leading directories</p>
          </div>
          {recognitions.map((item) => (
            <div class="md:px-5 md:py-1 lg:px-6">
              <p class="text-base font-medium leading-snug tracking-tight text-secondary-4">{item.title}</p>
              <p class="mt-1.5 text-[11px] leading-snug text-secondary-2/80">{item.source}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mt-12 border-b border-secondary-2/[0.08] pb-12 md:mt-14 md:pb-14">
        <div class="grid grid-cols-1 gap-10 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)] lg:gap-14 xl:gap-16">
          <div class="max-w-2xl space-y-6 text-pretty text-base leading-[1.75] text-secondary-3 md:space-y-7 lg:max-w-[42rem]">
            {biographyParagraphs.map((para) => (
              <p>{para}</p>
            ))}
          </div>
          <aside class="lg:border-l lg:border-secondary-2/[0.08] lg:pl-8 xl:pl-10">
            <h2 class="text-xs font-medium uppercase tracking-wider text-secondary-2/90">Expertise</h2>
            <ul class="mt-5 space-y-0">
              {expertise.map((item) => (
                <li class="border-b border-secondary-2/[0.06] py-3.5 last:border-b-0 last:pb-0">
                  <span class="text-sm text-secondary-4">{item}</span>
                  <span class="ml-1.5 text-secondary-2/70">→</span>
                </li>
              ))}
            </ul>
          </aside>
        </div>
      </section>

      <section class="mt-12 border-b border-secondary-2/[0.08] pb-12 md:mt-16 md:pb-14">
        <div class="mb-6 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between sm:gap-4 md:mb-8">
          <h2 class="max-w-xl text-xs font-medium uppercase tracking-wider text-secondary-2/90">
            Situations this practitioner helps clients manage
          </h2>
          <span class="shrink-0 text-xs text-secondary-3/90">View all situations →</span>
        </div>
        <div class="grid grid-cols-1 gap-y-8 gap-x-6 sm:gap-y-9 md:grid-cols-2 md:gap-x-8 xl:grid-cols-4 xl:gap-x-6">
          {situations.map((item) => (
            <article class="border-b border-secondary-2/[0.06] pb-6 last:border-0 sm:border-0 sm:pb-0 md:pb-2">
              <h3 class="text-sm font-medium leading-snug text-secondary-4">{item.title}</h3>
              <p class="mt-2 text-xs leading-relaxed text-secondary-3/95">{item.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="mt-14 bg-utility-2/20 px-1 py-8 md:mt-16 md:grid md:grid-cols-3 md:gap-0 md:px-0 md:py-10 lg:mt-20 lg:py-12">
        <div class="md:border-r md:border-secondary-2/[0.08] md:px-6 lg:px-8">
          <h2 class="text-xs font-medium uppercase tracking-wider text-secondary-2/90">Insights & publications</h2>
          <ul class="mt-4 space-y-4">
            {publications.map((item) => (
              <li>
                <p class="text-sm font-normal leading-snug text-secondary-4">{item.title}</p>
                <p class="mt-1 text-xs text-secondary-2/75">{item.date}</p>
              </li>
            ))}
          </ul>
          <p class="mt-5 text-xs text-secondary-3/90">View all insights →</p>
        </div>
        <div class="mt-8 md:mt-0 md:border-r md:border-secondary-2/[0.08] md:px-6 lg:px-8">
          <h2 class="text-xs font-medium uppercase tracking-wider text-secondary-2/90">Education & memberships</h2>
          <ul class="mt-4 space-y-2.5 text-xs leading-relaxed text-secondary-3">
            {memberships.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
        <div class="mt-8 md:mt-0 md:px-6 lg:px-8">
          <h2 class="text-xs font-medium uppercase tracking-wider text-secondary-2/90">Get in touch</h2>
          <p class="mt-4 text-sm leading-snug text-secondary-4">To discuss a matter confidentially, please get in touch:</p>
          <ul class="mt-3 space-y-2 text-xs leading-relaxed text-secondary-3">
            <li>+44 (0)20 0000 0000 (placeholder)</li>
            <li>alex.hartwell.benchmark@example.com</li>
            <li>Example Office, Fictional Address, London (layout only)</li>
          </ul>
        </div>
      </section>

      <p class="mt-12 md:mt-14">
        <a class="text-sm font-medium text-secondary-4 underline hover:text-secondary-3" href={localeHref(locale, '')}>
          ← Home
        </a>
      </p>
    </article>
  </DocumentMain>
</Base>
