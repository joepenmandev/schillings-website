---
import Base from '@/layouts/Base.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import DocumentMain from '@/components/DocumentMain.astro';
import { publishedPeople } from '@/data/people';
import { EXPERTISE_IDS, EXPERTISE_LABELS, type ExpertiseId } from '@/data/people-taxonomy';
import PersonColleagueCard from '@/components/PersonColleagueCard.astro';
import ServiceHubInternalNav from '@/components/ServiceHubInternalNav.astro';
import { getServiceHubCopy } from '@/lib/service-hub-copy';
import { clipPlainText } from '@/lib/person-jsonld';
import { isExpertiseId, peopleForExpertise } from '@/lib/service-hubs';
import { breadcrumbListGraphNode } from '@/lib/jsonld-breadcrumbs';
import { buildJsonLdGraph, buildPageEntityJsonLd } from '@/lib/jsonld-page';
import { absolutePageUrl } from '@/lib/public-url';
import { localeHref } from '@/lib/site-nav';
import { locales, isLocale, type Locale } from '@/i18n/config';

export function getStaticPaths() {
  return EXPERTISE_IDS.map((expertiseId) => ({ params: { expertiseId } }));
}

const expertiseIdRaw = Astro.params.expertiseId;
if (typeof expertiseIdRaw !== 'string' || !isExpertiseId(expertiseIdRaw)) {
  return new Response(null, { status: 404 });
}
const locale = 'en-gb';
const expertiseId = expertiseIdRaw as ExpertiseId;
const label = EXPERTISE_LABELS[expertiseId];
const people = peopleForExpertise(publishedPeople(), expertiseId);
const servicesIndex = localeHref(locale, 'services');
const copy = getServiceHubCopy(expertiseId);
const metaDesc = clipPlainText(`${label}: ${copy.intro}`, 158);
const origin = (Astro.site ?? new URL('https://schillingspartners.com')).href.replace(/\/$/, '');
const hubUrl = `${absolutePageUrl(origin, locale, `services/${expertiseId}`)}`;
const hubTitle = `${label} | Services | Schillings`;
const hubJsonLd = buildJsonLdGraph(
  buildPageEntityJsonLd({
    origin,
    locale,
    pathSegment: `services/${expertiseId}`,
    pageType: 'WebPage',
    name: hubTitle,
    description: metaDesc,
  }),
  breadcrumbListGraphNode([
    { name: 'Home', item: `${absolutePageUrl(origin, locale, '')}` },
    { name: 'Services', item: `${absolutePageUrl(origin, locale, 'services')}` },
    { name: label, item: hubUrl },
  ]),
);
---

<Base
  title={hubTitle}
  description={metaDesc}
  {locale}
  pathAfterLocale={`services/${expertiseId}`}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(hubJsonLd)} />
  <SiteHeader {locale} />
  <DocumentMain>
    <p class="text-xs font-normal uppercase tracking-wide text-secondary-2">
      <a href={servicesIndex} class="text-secondary-4 underline hover:text-secondary-3">Services</a>
      <span aria-hidden="true"> / </span>
      <span>{label}</span>
    </p>
    <h1 class="mt-2 text-3xl font-extralight leading-tight tracking-tight text-secondary-4 md:text-[3.125rem] md:leading-[1.1]">
      {label}
    </h1>
    <p class="mt-4 max-w-3xl text-pretty text-base leading-relaxed text-secondary-3">{copy.intro}</p>
    {
      copy.bullets && copy.bullets.length > 0 ? (
        <ul class="mt-6 max-w-3xl list-disc space-y-2 pl-5 text-pretty text-base leading-relaxed text-secondary-3">
          {copy.bullets.map((b) => (
            <li>{b}</li>
          ))}
        </ul>
      ) : null
    }
    <aside class="mt-8 max-w-3xl rounded border border-secondary-2/30 bg-utility-2/50 px-4 py-3 text-sm leading-relaxed text-secondary-3">
      {copy.legalNote}
    </aside>

    <ServiceHubInternalNav {locale} />

    <section class="mt-12" aria-labelledby="svc-people-heading">
      <h2 id="svc-people-heading" class="text-sm font-medium uppercase tracking-wide text-secondary-2">
        People
      </h2>
      {
        people.length === 0 ? (
          <p class="mt-3 text-sm text-secondary-3">No profiles mapped to this expertise in the current import.</p>
        ) : (
          <ul class="mt-6 grid list-none gap-x-6 gap-y-10 p-0 sm:grid-cols-2 lg:grid-cols-3 lg:gap-x-8">
            {people.map((p) => (
              <li class="min-w-0">
                <PersonColleagueCard locale={locale} person={p} variant="grid" />
              </li>
            ))}
          </ul>
        )
      }
    </section>

    <p class="mt-10">
      <a class="text-sm font-medium text-secondary-4 underline hover:text-secondary-3" href={servicesIndex}>← All services</a>
    </p>
  </DocumentMain>
</Base>
