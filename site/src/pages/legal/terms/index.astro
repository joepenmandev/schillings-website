---
import { localeHref } from '@/lib/site-nav';
import Base from '@/layouts/Base.astro';
import MarketingStubNav from '@/components/MarketingStubNav.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import DocumentMain from '@/components/DocumentMain.astro';
import { locales, isLocale } from '@/i18n/config';

const locale = 'en-gb';
---

<Base
  title="Terms | Schillings"
  description="Website terms of use — placeholder pending approved copy."
  locale={locale}
  pathAfterLocale="legal/terms"
>
  <SiteHeader locale={locale} />
  <DocumentMain>
    <h1 class="text-3xl font-extralight leading-tight tracking-tight text-secondary-4 md:text-[3.125rem] md:leading-[1.1]">
      Terms
    </h1>
    <p class="mt-4 text-pretty text-secondary-3">
      Placeholder — replace with approved website terms. For engagement terms see{' '}
      <a class="text-secondary-4 underline hover:text-secondary-3" href={localeHref(locale, 'compliance/standard-terms-of-business')}>
        Standard Terms of Business
      </a>
      . <code class="rounded bg-utility-2 px-1 text-sm text-secondary-4">IA-URL-SPEC.md</code> §1.
    </p>
    <MarketingStubNav {locale} currentSegment="legal/terms" />
  </DocumentMain>
</Base>
