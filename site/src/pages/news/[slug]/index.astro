---
import { absolutePageUrl } from '@/lib/public-url';
import { localeHref } from '@/lib/site-nav';
import Base from '@/layouts/Base.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import DocumentMain from '@/components/DocumentMain.astro';
import NewsArticleAuthorFoot from '@/components/NewsArticleAuthorFoot.astro';
import NewsArticleLatestByAuthors from '@/components/NewsArticleLatestByAuthors.astro';
import NewsArticlePostHero from '@/components/NewsArticlePostHero.astro';
import { getNewsBySlug } from '@/data/news';
import { getPersonBySlug } from '@/data/people';
import { absoluteOgImageUrl } from '@/lib/absolute-media-url';
import { breadcrumbListJsonLd } from '@/lib/jsonld-breadcrumbs';
import { buildNewsArticleBlogPostingGraph } from '@/lib/jsonld-article';
import { firstNonemptyParagraphIndex, newsExcerpt, newsHeroDisplaySrc } from '@/lib/news-render';
import { getAllNewsSlugs } from '@/lib/news-paths';

export function getStaticPaths() {
  const slugs = getAllNewsSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

function titleFromSlug(slug: string) {
  return slug
    .split('-')
    .filter(Boolean)
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
}

const slug = Astro.params.slug;
if (typeof slug !== 'string') {
  return new Response(null, { status: 404 });
}
const locale = 'en-gb';
const allowedSlugs = new Set(getAllNewsSlugs());
if (!allowedSlugs.has(slug)) {
  return new Response(null, { status: 404 });
}

const article = getNewsBySlug(slug);
const isMigration = !article;

const origin = (Astro.site ?? new URL('https://schillingspartners.com')).href.replace(/\/$/, '');

const migrationTitle = titleFromSlug(slug);
const migrationDescription =
  'This article is being migrated to the new Schillings site. Please check back or contact us for the latest version.';

let blogJsonLd: object | null = null;
let breadcrumbJsonLd: object | null = null;
let pageTitle = '';
let pageDescription = '';
let pathAfterLocale = '';
let articleOgImage: string | undefined;
let articleHeroSrc: string | undefined;
let articleLedeParagraphIndex = -1;

if (article) {
  pageTitle = `${article.title} | Schillings`;
  pageDescription = newsExcerpt(article);
  pathAfterLocale = `news/${article.slug}`;
  const pageUrl = `${absolutePageUrl(origin, locale, `news/${article.slug}`)}`;
  const heroRaw = newsHeroDisplaySrc(article)?.trim();
  articleOgImage = absoluteOgImageUrl(origin, heroRaw);
  articleHeroSrc =
    heroRaw == null || heroRaw === ''
      ? undefined
      : heroRaw.startsWith('http')
        ? heroRaw
        : heroRaw.startsWith('/')
          ? heroRaw
          : `/${heroRaw}`;
  blogJsonLd = buildNewsArticleBlogPostingGraph({
    origin,
    locale,
    article,
    pageUrl,
    resolvePerson: getPersonBySlug,
  });
  articleLedeParagraphIndex = firstNonemptyParagraphIndex(article.paragraphs);
  breadcrumbJsonLd = breadcrumbListJsonLd([
    { name: 'Home', item: `${absolutePageUrl(origin, locale, '')}` },
    { name: 'News & Insights', item: `${absolutePageUrl(origin, locale, 'news')}` },
    { name: article.title, item: pageUrl },
  ]);
} else {
  pageTitle = `${migrationTitle} | Schillings`;
  pageDescription = migrationDescription;
  pathAfterLocale = `news/${slug}`;
}
---

<Base
  title={pageTitle}
  description={pageDescription}
  {locale}
  pathAfterLocale={pathAfterLocale}
  noindex={isMigration}
  ogImage={articleOgImage}
  ogType={article ? 'article' : 'website'}
  hreflangLocales={isMigration ? [locale] : undefined}
>
  {blogJsonLd && <script type="application/ld+json" slot="head" set:html={JSON.stringify(blogJsonLd)} />}
  {breadcrumbJsonLd && <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbJsonLd)} />}
  <SiteHeader {locale} deferHeaderLogoPriority={!!(article && articleHeroSrc)} />
  <DocumentMain contentWidth="wide">
    <article>
      {
        article ? (
          <>
            <NewsArticlePostHero {locale} {article} />
            <div class="article-body mt-10 rounded-lg border border-secondary-2/15 bg-utility-1/90 px-4 py-8 sm:px-8 md:mt-12 md:px-12 md:py-12">
              <div class="mx-auto max-w-3xl space-y-5 text-pretty text-base font-normal leading-relaxed text-secondary-3">
                {article.paragraphs.map((p, i) => (
                  <p id={i === articleLedeParagraphIndex && articleLedeParagraphIndex >= 0 ? 'article-lede' : undefined}>{p}</p>
                ))}
              </div>
            </div>
            <NewsArticleAuthorFoot {locale} {article} />
            <NewsArticleLatestByAuthors {locale} {article} />
          </>
        ) : (
          <>
            <p class="text-xs font-normal uppercase tracking-wide text-secondary-2">News &amp; Insights</p>
            <h1 class="mt-2 text-3xl font-extralight leading-tight tracking-tight text-secondary-4 md:text-[3.125rem] md:leading-[1.1]">
              {migrationTitle}
            </h1>
            <p class="mt-6 text-pretty text-base font-normal leading-relaxed text-secondary-3">{migrationDescription}</p>
            <p class="mt-4 text-sm text-secondary-3">
              Slug preserved for redirects: <code class="rounded bg-utility-2 px-1.5 py-0.5 text-secondary-4">{slug}</code>
            </p>
          </>
        )
      }
      <p class="mt-10">
        <a class="text-sm font-medium text-secondary-4 underline hover:text-secondary-3" href={localeHref(locale, 'news')}>
          ← Back to News & Insights
        </a>
      </p>
    </article>
  </DocumentMain>
</Base>
