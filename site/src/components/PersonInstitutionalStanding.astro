---
/**
 * Quiet editorial standing from existing recognition rows only (no badge chrome).
 */
import type { PersonRecognition } from '@/data/people';
import { resolveRecognitionOutboundHref } from '@/lib/person-recognition-href';

export interface Props {
  recognitions: PersonRecognition[];
  personName: string;
}

const { recognitions, personName } = Astro.props;

const PROVIDER_ORDER: Partial<Record<PersonRecognition['provider'], number>> = {
  chambers: 0,
  legal500: 1,
  spears: 2,
  other: 3,
};

function publisherLine(item: PersonRecognition): string {
  if (item.provider === 'chambers') return 'Chambers & Partners';
  if (item.provider === 'legal500') return 'The Legal 500';
  if (item.provider === 'spears') return "Spear's 500";
  const h = item.href?.toLowerCase() ?? '';
  if (h.includes('billboard.com')) return 'Billboard';
  return 'Recognition';
}

const sorted = [...recognitions].sort(
  (a, b) => (PROVIDER_ORDER[a.provider] ?? 9) - (PROVIDER_ORDER[b.provider] ?? 9),
);

const indexLinkClass =
  'block py-[1.4rem] text-inherit no-underline decoration-secondary-2/0 underline-offset-[0.2em] transition-[text-decoration-color] first:pt-[1.1rem] hover:underline hover:decoration-secondary-2/22 focus-visible:outline focus-visible:outline-1 focus-visible:outline-offset-2 focus-visible:outline-secondary-3/40';
---

{
  sorted.length > 0 ? (
    <section class="mt-8 max-w-[26rem] lg:mt-9" aria-labelledby="institutional-standing-heading">
      <p id="institutional-standing-heading" class="text-[0.52rem] font-normal uppercase tracking-[0.21em] text-secondary-2/58">
        Institutional standing
      </p>
      <ul class="mt-6 border-t border-secondary-2/[0.07]" role="list">
        {sorted.map((item) => {
          const href = resolveRecognitionOutboundHref(item);
          const pub = publisherLine(item);
          const detail = [item.title, item.year].filter(Boolean).join(' · ');
          const body = (
            <>
              <div class="flex flex-col gap-1.5 sm:flex-row sm:items-baseline sm:justify-between sm:gap-4">
                <span class="text-[0.5rem] font-normal uppercase tracking-[0.17em] text-secondary-2/44">{pub}</span>
                {item.year ? (
                  <span class="text-[0.48rem] tabular-nums tracking-wide text-secondary-2/38">{item.year}</span>
                ) : null}
              </div>
              <p class="mt-2.5 max-w-[20rem] text-pretty font-serif text-[0.78125rem] font-extralight leading-[1.52] text-secondary-3/[0.92]">
                {item.title}
              </p>
            </>
          );
          return (
            <li class="border-b border-secondary-2/[0.055] last:border-b-0">
              {href ? (
                <a href={href} rel="noopener noreferrer" target="_blank" class={indexLinkClass}>
                  {body}
                  <span class="sr-only"> — {detail} (opens in new tab)</span>
                </a>
              ) : (
                <div class="py-[1.4rem]">{body}</div>
              )}
            </li>
          );
        })}
      </ul>
      <p class="mt-8 max-w-[20rem] text-pretty text-[0.6rem] leading-[1.65] text-secondary-2/50">
        Independent listings shown for {personName}. Methodologies are set by each publisher; Schillings does not control
        external sites or rankings.
      </p>
    </section>
  ) : null
}
