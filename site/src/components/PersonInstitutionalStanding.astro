---
/**
 * Quiet editorial standing from existing recognition rows only (no badge chrome).
 */
import type { PersonRecognition } from '@/data/people';
import { resolveRecognitionOutboundHref } from '@/lib/person-recognition-href';

export interface Props {
  recognitions: PersonRecognition[];
  personName: string;
}

const { recognitions, personName } = Astro.props;

const PROVIDER_ORDER: Partial<Record<PersonRecognition['provider'], number>> = {
  chambers: 0,
  legal500: 1,
  spears: 2,
  other: 3,
};

function publisherLine(item: PersonRecognition): string {
  if (item.provider === 'chambers') return 'Chambers & Partners';
  if (item.provider === 'legal500') return 'The Legal 500';
  if (item.provider === 'spears') return "Spear's 500";
  const h = item.href?.toLowerCase() ?? '';
  if (h.includes('billboard.com')) return 'Billboard';
  return 'Recognition';
}

const sorted = [...recognitions].sort(
  (a, b) => (PROVIDER_ORDER[a.provider] ?? 9) - (PROVIDER_ORDER[b.provider] ?? 9),
);
---

{
  sorted.length > 0 ? (
    <section class="mt-8 max-w-2xl lg:mt-9" aria-labelledby="institutional-standing-heading">
      <p id="institutional-standing-heading" class="text-[0.65rem] font-medium uppercase tracking-[0.14em] text-secondary-2">
        Institutional standing
      </p>
      <ul class="mt-4 border-t border-secondary-2/20" role="list">
        {sorted.map((item) => {
          const href = resolveRecognitionOutboundHref(item);
          const pub = publisherLine(item);
          const detail = [item.title, item.year].filter(Boolean).join(' · ');
          const body = (
            <>
              <div class="flex flex-col gap-0.5 sm:flex-row sm:items-baseline sm:justify-between sm:gap-4">
                <span class="text-[0.65rem] font-medium uppercase tracking-[0.12em] text-secondary-2">{pub}</span>
                {item.year ? (
                  <span class="text-[0.65rem] tabular-nums tracking-wide text-secondary-2/80">{item.year}</span>
                ) : null}
              </div>
              <p class="mt-1.5 max-w-xl text-pretty font-serif text-[1.05rem] font-normal leading-snug text-secondary-4">{item.title}</p>
            </>
          );
          return (
            <li class="border-b border-secondary-2/15 py-4 first:pt-4 last:border-b-0">
              {href ? (
                <a
                  href={href}
                  rel="noopener noreferrer"
                  target="_blank"
                  class="group block -mx-1 rounded-sm px-1 transition-colors hover:bg-utility-2/40 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary-3/60"
                >
                  {body}
                  <span class="sr-only"> — {detail} (opens in new tab)</span>
                </a>
              ) : (
                body
              )}
            </li>
          );
        })}
      </ul>
      <p class="mt-4 max-w-xl text-pretty text-[0.7rem] leading-relaxed text-secondary-2">
        Independent listings shown for {personName}. Methodologies are set by each publisher; Schillings does not control
        external sites or rankings.
      </p>
    </section>
  ) : null
}
