---
/**
 * Quiet editorial standing from existing recognition rows only (no badge chrome).
 * Tiered hierarchy: core legal directories read as primary citations; other publishers as supporting.
 */
import type { PersonRecognition } from '@/data/people';
import { resolveRecognitionOutboundHref } from '@/lib/person-recognition-href';

export interface Props {
  recognitions: PersonRecognition[];
  personName: string;
}

const { recognitions, personName } = Astro.props;

const PROVIDER_ORDER: Partial<Record<PersonRecognition['provider'], number>> = {
  chambers: 0,
  legal500: 1,
  spears: 2,
  other: 3,
};

function publisherLine(item: PersonRecognition): string {
  if (item.provider === 'chambers') return 'Chambers & Partners';
  if (item.provider === 'legal500') return 'The Legal 500';
  if (item.provider === 'spears') return "Spear's 500";
  const h = item.href?.toLowerCase() ?? '';
  if (h.includes('billboard.com')) return 'Billboard';
  return 'Recognition';
}

function citationTier(provider: PersonRecognition['provider']): 'primary' | 'secondary' {
  if (provider === 'chambers' || provider === 'legal500') return 'primary';
  return 'secondary';
}

const sorted = [...recognitions].sort(
  (a, b) => (PROVIDER_ORDER[a.provider] ?? 9) - (PROVIDER_ORDER[b.provider] ?? 9),
);
---

{
  sorted.length > 0 ? (
    <section class="mt-4 max-w-[25rem] lg:mt-5" aria-labelledby="institutional-standing-heading">
      <p
        id="institutional-standing-heading"
        class="font-[system-ui,sans-serif] text-[0.5625rem] font-normal uppercase tracking-[0.13em] text-secondary-2/36"
      >
        Publisher citations
      </p>
      <ul class="mt-[0.625rem] border-t border-secondary-2/[0.028]" role="list">
        {sorted.map((item, idx) => {
          const href = resolveRecognitionOutboundHref(item);
          const pub = publisherLine(item);
          const tier = citationTier(item.provider);
          const prevTier = idx > 0 ? citationTier(sorted[idx - 1]!.provider) : null;
          const shelfBreak = idx > 0 && prevTier === 'primary' && tier === 'secondary';
          const detail = [item.title, item.year].filter(Boolean).join(' · ');

          const pubClass =
            tier === 'primary'
              ? 'font-[system-ui,sans-serif] text-[0.46875rem] font-normal uppercase tracking-[0.1em] text-secondary-2/36'
              : 'font-[system-ui,sans-serif] text-[0.45rem] font-normal uppercase tracking-[0.09em] text-secondary-2/30';

          const yearClass =
            tier === 'primary'
              ? 'font-[system-ui,sans-serif] text-[0.4375rem] tabular-nums tracking-wide text-secondary-2/30'
              : 'font-[system-ui,sans-serif] text-[0.421875rem] tabular-nums tracking-wide text-secondary-2/26';

          const titleClass =
            tier === 'primary'
              ? 'mt-[0.3125rem] max-w-[21rem] text-pretty font-[system-ui,sans-serif] text-[0.796875rem] font-normal leading-[1.46] text-secondary-3/[0.86]'
              : 'mt-[0.1875rem] max-w-[20rem] text-pretty font-[system-ui,sans-serif] text-[0.71875rem] font-normal leading-[1.44] text-secondary-3/[0.78]';

          const blockPad =
            tier === 'primary' ? 'py-[0.72rem] first:pt-[0.62rem]' : 'py-[0.56rem] last:pb-[0.62rem]';

          const linkClass = [
            'block text-inherit no-underline decoration-secondary-2/0 underline-offset-[0.2em]',
            blockPad,
            'hover:underline hover:decoration-secondary-2/12 focus-visible:outline focus-visible:outline-1 focus-visible:outline-offset-2 focus-visible:outline-secondary-3/32',
          ];

          const body = (
            <>
              <div class="flex flex-col gap-0.5 sm:flex-row sm:items-baseline sm:justify-between sm:gap-3">
                <span class={pubClass}>{pub}</span>
                {item.year ? <span class={yearClass}>{item.year}</span> : null}
              </div>
              <p class={titleClass}>{item.title}</p>
            </>
          );

          return (
            <li class:list={[shelfBreak && 'mt-[0.3125rem] border-t border-secondary-2/[0.018] pt-[0.59375rem]']}>
              {href ? (
                <a href={href} rel="noopener noreferrer" target="_blank" class:list={linkClass}>
                  {body}
                  <span class="sr-only"> — {detail} (opens in new tab)</span>
                </a>
              ) : (
                <div class:list={[blockPad]}>{body}</div>
              )}
            </li>
          );
        })}
      </ul>
      <p class="mt-[0.6875rem] max-w-[20rem] text-pretty font-[system-ui,sans-serif] text-[0.546875rem] leading-[1.5] text-secondary-2/34">
        Third-party pages only; each publisher sets methodology and copy.
      </p>
    </section>
  ) : null
}
