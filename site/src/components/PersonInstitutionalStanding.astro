---
/**
 * Quiet editorial standing from existing recognition rows only (no badge chrome).
 */
import type { PersonRecognition } from '@/data/people';
import { resolveRecognitionOutboundHref } from '@/lib/person-recognition-href';

export interface Props {
  recognitions: PersonRecognition[];
  personName: string;
}

const { recognitions, personName } = Astro.props;

const PROVIDER_ORDER: Partial<Record<PersonRecognition['provider'], number>> = {
  chambers: 0,
  legal500: 1,
  spears: 2,
  other: 3,
};

function publisherLine(item: PersonRecognition): string {
  if (item.provider === 'chambers') return 'Chambers & Partners';
  if (item.provider === 'legal500') return 'The Legal 500';
  if (item.provider === 'spears') return "Spear's 500";
  const h = item.href?.toLowerCase() ?? '';
  if (h.includes('billboard.com')) return 'Billboard';
  return 'Recognition';
}

const sorted = [...recognitions].sort(
  (a, b) => (PROVIDER_ORDER[a.provider] ?? 9) - (PROVIDER_ORDER[b.provider] ?? 9),
);

const indexLinkClass =
  'block py-[1.05rem] text-inherit no-underline decoration-secondary-2/0 underline-offset-[0.2em] transition-[text-decoration-color] hover:underline hover:decoration-secondary-2/28 focus-visible:outline focus-visible:outline-1 focus-visible:outline-offset-2 focus-visible:outline-secondary-3/45';
---

{
  sorted.length > 0 ? (
    <section class="mt-10 max-w-[28rem] lg:mt-[2.75rem]" aria-labelledby="institutional-standing-heading">
      <p id="institutional-standing-heading" class="text-[0.56rem] font-normal uppercase tracking-[0.2em] text-secondary-2/70">
        Institutional standing
      </p>
      <ul class="mt-5 border-t border-secondary-2/[0.11]" role="list">
        {sorted.map((item, i) => {
          const href = resolveRecognitionOutboundHref(item);
          const pub = publisherLine(item);
          const detail = [item.title, item.year].filter(Boolean).join(' · ');
          const body = (
            <>
              <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between sm:gap-4">
                <span class="text-[0.56rem] font-normal uppercase tracking-[0.15em] text-secondary-2/62">{pub}</span>
                {item.year ? (
                  <span class="text-[0.52rem] tabular-nums tracking-wide text-secondary-2/48">{item.year}</span>
                ) : null}
              </div>
              <p class="mt-2 max-w-[22rem] text-pretty font-serif text-[0.8125rem] font-extralight leading-[1.5] text-secondary-3">
                {item.title}
              </p>
            </>
          );
          return (
            <li
              class:list={[
                'border-b border-secondary-2/[0.09] last:border-b-0',
                i === 0 && 'pt-1',
              ]}
            >
              {href ? (
                <a href={href} rel="noopener noreferrer" target="_blank" class={indexLinkClass}>
                  {body}
                  <span class="sr-only"> — {detail} (opens in new tab)</span>
                </a>
              ) : (
                <div class="py-[1.05rem]">{body}</div>
              )}
            </li>
          );
        })}
      </ul>
      <p class="mt-6 max-w-[22rem] text-pretty text-[0.65rem] leading-[1.6] text-secondary-2/62">
        Independent listings shown for {personName}. Methodologies are set by each publisher; Schillings does not control
        external sites or rankings.
      </p>
    </section>
  ) : null
}
