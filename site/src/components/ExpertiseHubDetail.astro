---
import Base from '@/layouts/Base.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import DocumentMain from '@/components/DocumentMain.astro';
import { publishedPeople } from '@/data/people';
import { EXPERTISE_LABELS, type ExpertiseId } from '@/data/people-taxonomy';
import PersonColleagueCard from '@/components/PersonColleagueCard.astro';
import ServiceHubInternalNav from '@/components/ServiceHubInternalNav.astro';
import { getServiceHubCopy } from '@/lib/service-hub-copy';
import { clipPlainText } from '@/lib/person-jsonld';
import { expertisePathSlug } from '@/lib/expertise-paths';
import { peopleForExpertise } from '@/lib/service-hubs';
import { breadcrumbListGraphNode } from '@/lib/jsonld-breadcrumbs';
import { buildJsonLdGraph, buildPageEntityJsonLd } from '@/lib/jsonld-page';
import { absolutePageUrl } from '@/lib/public-url';
import { contactSegment, EXPERTISE_PUBLIC_SEGMENT, localeHref } from '@/lib/site-nav';
import type { Locale } from '@/i18n/config';

interface Props {
  locale: Locale;
  expertiseId: ExpertiseId;
}

const { locale, expertiseId } = Astro.props;

const label = EXPERTISE_LABELS[expertiseId];
const people = peopleForExpertise(publishedPeople(), expertiseId);
const expertiseIndexHref = localeHref(locale, EXPERTISE_PUBLIC_SEGMENT);
const copy = getServiceHubCopy(expertiseId);
const metaDesc = clipPlainText(`${label}: ${copy.intro}`, 158);
const origin = Astro.site?.origin ?? Astro.url.origin;
const publicSlug = expertisePathSlug(expertiseId);
const hubUrl = `${absolutePageUrl(origin, locale, `${EXPERTISE_PUBLIC_SEGMENT}/${publicSlug}`)}`;
const hubTitle = `${label} | Expertise | Schillings`;
const pathSegment = `${EXPERTISE_PUBLIC_SEGMENT}/${publicSlug}`;
const hubJsonLd = buildJsonLdGraph(
  buildPageEntityJsonLd({
    origin,
    locale,
    pathSegment,
    pageType: 'WebPage',
    name: hubTitle,
    description: metaDesc,
  }),
  breadcrumbListGraphNode([
    { name: 'Home', item: `${absolutePageUrl(origin, locale, '')}` },
    { name: 'Expertise', item: `${absolutePageUrl(origin, locale, EXPERTISE_PUBLIC_SEGMENT)}` },
    { name: label, item: hubUrl },
  ]),
);

const contactHref = localeHref(locale, contactSegment);
const crumbClass =
  'text-secondary-2 underline decoration-secondary-2/40 underline-offset-[0.15em] transition-colors hover:text-secondary-3 hover:decoration-secondary-3';
const sectionTitle =
  'text-xs font-medium uppercase tracking-[0.18em] text-secondary-2';
---

<Base title={hubTitle} description={metaDesc} {locale} pathAfterLocale={pathSegment}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(hubJsonLd)} />
  <SiteHeader {locale} />
  <DocumentMain contentWidth="wide">
    <article class="mx-auto max-w-3xl">
      <nav aria-label="Breadcrumb" class="text-xs font-normal text-secondary-3">
        <ol class="flex flex-wrap items-center gap-x-2 gap-y-1">
          <li>
            <a href={localeHref(locale, '')} class={crumbClass}>Home</a>
          </li>
          <li class="text-secondary-2/50" aria-hidden="true">/</li>
          <li>
            <a href={expertiseIndexHref} class={crumbClass}>Expertise</a>
          </li>
          <li class="text-secondary-2/50" aria-hidden="true">/</li>
          <li class="text-secondary-4" aria-current="page">{label}</li>
        </ol>
      </nav>

      <header class="mt-8 md:mt-10">
        <h1 class="font-serif text-pretty text-3xl font-extralight leading-tight tracking-tight text-secondary-4 md:text-[3.125rem] md:leading-[1.1]">
          {label}
        </h1>
        <p class="mt-6 max-w-3xl text-pretty text-base font-normal leading-relaxed text-secondary-3 md:text-[1.05rem] md:leading-[1.65]">
          {copy.intro}
        </p>
      </header>

      {
        copy.bullets && copy.bullets.length > 0 ? (
          <section class="mt-10 md:mt-12" aria-labelledby="expertise-bullets-heading">
            <h2 id="expertise-bullets-heading" class={sectionTitle}>
              Key capabilities
            </h2>
            <ul class="mt-4 list-none space-y-3 text-pretty text-base font-extralight leading-relaxed text-secondary-3 md:mt-5 md:text-[1.05rem]">
              {copy.bullets.map((b) => (
                <li class="flex gap-3">
                  <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-secondary-3/70" aria-hidden="true" />
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </section>
        ) : null
      }

      <aside
        class="mt-10 max-w-3xl rounded-lg border border-secondary-2/15 bg-utility-1/90 px-5 py-6 text-pretty text-sm font-extralight leading-relaxed text-secondary-3 md:mt-12 md:px-6 md:py-7 md:text-[0.9375rem]"
      >
        {copy.legalNote}
      </aside>

      <div class="mt-10 md:mt-12">
        <ServiceHubInternalNav {locale} />
      </div>

      <section class="mt-10 md:mt-12" aria-labelledby="expertise-hub-people-heading">
        <h2 id="expertise-hub-people-heading" class={sectionTitle}>
          People
        </h2>
        {
          people.length === 0 ? (
            <p class="mt-4 text-pretty text-base font-extralight leading-relaxed text-secondary-3 md:mt-5 md:text-[1.05rem]">
              No profiles mapped to this expertise in the current import.
            </p>
          ) : (
            <ul class="mt-4 grid list-none gap-x-6 gap-y-10 p-0 sm:grid-cols-2 md:mt-5 lg:grid-cols-3 lg:gap-x-8">
              {people.map((p) => (
                <li class="min-w-0">
                  <PersonColleagueCard locale={locale} person={p} variant="grid" />
                </li>
              ))}
            </ul>
          )
        }
      </section>

      <section
        class="mt-12 rounded-sm border border-secondary-2/20 bg-utility-2/35 px-5 py-8 md:mt-14 md:px-8 md:py-10"
        aria-labelledby="expertise-cta-heading"
      >
        <h2 id="expertise-cta-heading" class="sr-only">Confidential enquiry</h2>
        <p class="text-pretty text-base font-extralight leading-relaxed text-secondary-3 md:text-[1.05rem]">
          If you need to protect reputation, privacy, family, or continuity under pressure, we can discuss your context in
          confidence.
        </p>
        <p class="mt-6">
          <a
            href={contactHref}
            class="inline-flex min-h-[2.75rem] items-center justify-center rounded-sm bg-secondary-4 px-6 py-3 text-center text-sm font-normal tracking-wide text-brand-white outline-offset-4 transition-opacity hover:opacity-92 focus-visible:outline focus-visible:outline-2 focus-visible:outline-secondary-4"
          >
            Speak confidentially
          </a>
        </p>
      </section>

      <p class="mt-10 text-sm md:mt-12">
        <a
          href={expertiseIndexHref}
          class="font-medium text-secondary-4 underline decoration-secondary-2/40 underline-offset-[0.2em] transition-colors hover:decoration-secondary-4"
        >
          ← Expertise
        </a>
      </p>
    </article>
  </DocumentMain>
</Base>
