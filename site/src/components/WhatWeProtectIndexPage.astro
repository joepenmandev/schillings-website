---
/**
 * `/what-we-protect/` — index with asset grid, response system summary, JSON-LD.
 */
import type { Locale } from '@/i18n/config';
import Base from '@/layouts/Base.astro';
import CtaConfidentialBand from '@/components/CtaConfidentialBand.astro';
import HubLinkCard from '@/components/HubLinkCard.astro';
import SectionKicker from '@/components/SectionKicker.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import StrategicBreadcrumb from '@/components/StrategicBreadcrumb.astro';
import StrategicPageTitle from '@/components/StrategicPageTitle.astro';
import DocumentMain from '@/components/DocumentMain.astro';
import { contactSegment, localeHref } from '@/lib/site-nav';
import {
  getStrategicHubPageModel,
  responseSystemPage,
  STRATEGIC_WHAT_WE_PROTECT_IDS,
  whatWeProtectDetailsById,
} from '@/data/strategic-rebuild-content';
import { buildJsonLdGraph, buildPageEntityJsonLd } from '@/lib/jsonld-page';
import { breadcrumbListGraphNode } from '@/lib/jsonld-breadcrumbs';
import { absolutePageUrl } from '@/lib/public-url';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const hub = getStrategicHubPageModel('what-we-protect');
const origin = Astro.site?.origin ?? Astro.url.origin;
const pathAfterLocale = 'what-we-protect';
const pageUrl = absolutePageUrl(origin, locale, pathAfterLocale);
const homeUrl = absolutePageUrl(origin, locale, '');
const jsonLd = buildJsonLdGraph(
  buildPageEntityJsonLd({
    origin,
    locale,
    pathSegment: pathAfterLocale,
    pageType: 'WebPage',
    name: hub.title,
    description: hub.metaDescription,
  }),
  breadcrumbListGraphNode([
    { name: 'Home', item: homeUrl },
    { name: hub.heading, item: pageUrl },
  ]),
);
const contactHref = localeHref(locale, contactSegment);
const responseSystemHref = localeHref(locale, 'response-system');
---

<Base title={hub.title} description={hub.metaDescription} {locale} {pathAfterLocale}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <SiteHeader {locale} />
  <DocumentMain contentWidth="wide">
    <article class="mx-auto max-w-6xl">
      <StrategicBreadcrumb
        items={[
          { label: 'Home', href: localeHref(locale, '') },
          { label: hub.heading },
        ]}
      />

      <header class="mt-8 md:mt-10">
        <StrategicPageTitle>{hub.heading}</StrategicPageTitle>
        <p class="mt-6 max-w-3xl text-pretty text-base font-extralight leading-relaxed text-secondary-3 md:text-[1.05rem] md:leading-[1.65]">
          {hub.intro}
        </p>
      </header>

      <section class="mt-12 md:mt-14" aria-labelledby="assets-grid-heading">
        <SectionKicker id="assets-grid-heading">{hub.listHeading}</SectionKicker>
        <ul class="mt-8 grid list-none gap-4 sm:grid-cols-2 lg:grid-cols-3 lg:gap-5" aria-label="Protective assets">
          {
            STRATEGIC_WHAT_WE_PROTECT_IDS.map((assetId) => {
              const d = whatWeProtectDetailsById[assetId];
              const tail = `what-we-protect/${d.slug}`;
              return (
                <li>
                  <HubLinkCard href={localeHref(locale, tail)}>
                    <span slot="title">{d.title}</span>
                    <span slot="description">View overview →</span>
                  </HubLinkCard>
                </li>
              );
            })
          }
        </ul>
      </section>

      <section
        class="mt-14 rounded-lg border border-secondary-2/15 bg-utility-1/90 px-5 py-8 md:mt-16 md:px-8 md:py-10"
        aria-labelledby="response-summary-heading"
      >
        <SectionKicker id="response-summary-heading">The Schillings response system</SectionKicker>
        <p class="mt-4 max-w-3xl text-pretty text-base font-extralight leading-relaxed text-secondary-3 md:mt-5 md:text-[1.05rem]">
          {responseSystemPage.lead}
        </p>
        <p class="mt-4 max-w-3xl font-serif text-lg font-extralight italic leading-relaxed text-secondary-3 md:text-xl">
          {responseSystemPage.tagline}
        </p>
        <p class="mt-6">
          <a
            href={responseSystemHref}
            class="text-sm font-medium text-secondary-4 underline decoration-secondary-2/45 underline-offset-[0.2em] transition-colors hover:decoration-secondary-4"
          >
            How the response system works
          </a>
        </p>
      </section>

      <CtaConfidentialBand
        class="mt-12 md:mt-14"
        headingId="wwp-cta-heading"
        srOnlyHeading="Confidential enquiry"
        href={contactHref}
        buttonText="Speak confidentially"
      >
        If you need to protect reputation, privacy, family, or continuity under pressure, we can discuss your context in confidence.
      </CtaConfidentialBand>
    </article>
  </DocumentMain>
</Base>
