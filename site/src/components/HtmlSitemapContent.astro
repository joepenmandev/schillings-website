---
import type { Locale } from '../i18n/config';
import { localeLabels, locales } from '../i18n/config';
import { localeHref } from '../lib/site-nav';
import { publicPathname } from '../lib/public-url';
import { buildHtmlSitemapGroups } from '../lib/page-route-discovery';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const label = localeLabels[locale];
const htmlSitemapGroups = buildHtmlSitemapGroups(locale);
const xmlSitemapIndexUrl = new URL('/sitemap-index.xml', Astro.url).href;
const regionalSitemapRows = locales.map((loc) => ({
  loc,
  label: localeLabels[loc],
  href: new URL(publicPathname(loc, 'sitemap'), Astro.url).href,
}));
---

<div class="space-y-12">
  <header class="space-y-3">
    <h1 class="text-3xl font-extralight leading-tight tracking-tight text-secondary-4 md:text-[3.125rem] md:leading-[1.1]">
      Sitemap
    </h1>
    <p class="max-w-2xl text-pretty text-secondary-3">
      Human-readable overview of main pages for the <strong class="font-normal text-secondary-4">{label}</strong> site. Search
      engines use the <a href={xmlSitemapIndexUrl} class="underline decoration-secondary-2/60 underline-offset-4"
        >XML sitemaps</a
      >.
    </p>
    <nav aria-label="Regional HTML sitemaps" class="mt-6 max-w-2xl">
      <h2 class="text-base font-normal tracking-tight text-secondary-4">Regional sitemaps</h2>
      <p class="mt-2 text-pretty text-sm text-secondary-3">
        Crawlable links to the same overview in each site region (complements <code class="text-secondary-4">hreflang</code>{' '}
        on every page).
      </p>
      <ul class="mt-3 flex flex-wrap gap-x-4 gap-y-2 text-secondary-4">
        {
          regionalSitemapRows.map(({ loc: locKey, label: regionLabel, href }) => (
            <li>
              <a
                href={href}
                class="underline decoration-secondary-2/60 underline-offset-4 transition-colors hover:text-secondary-3"
                aria-current={locKey === locale ? 'page' : undefined}
              >
                {regionLabel}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </header>
  {
    htmlSitemapGroups.map(({ heading, items }) => (
      <section class="space-y-4" aria-labelledby={`sitemap-${heading.replace(/\s+/g, '-').toLowerCase()}`}>
        <h2
          id={`sitemap-${heading.replace(/\s+/g, '-').toLowerCase()}`}
          class="text-lg font-normal tracking-tight text-secondary-4"
        >
          {heading}
        </h2>
        <ul class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
          {items.map(({ label: itemLabel, segment }) => (
            <li>
              <a
                href={new URL(localeHref(locale, segment), Astro.url).href}
                class="text-secondary-4 underline decoration-secondary-2/60 underline-offset-4 transition-colors hover:text-secondary-3"
              >
                {itemLabel}
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</div>
