---
import type { LinkedInsight } from '@/lib/platform/linking-rules';

interface Props {
  insights: LinkedInsight[];
}

const { insights } = Astro.props;
---

<section class="platform-card rounded-xl p-5">
  <h2 class="font-serif text-xl text-brand-white">Linked insights</h2>
  {insights.length ? (
    <ul class="mt-3 space-y-3 text-sm text-utility-2">
      {insights.map((insight) => <li>• <strong>{insight.label}</strong>: {insight.reason}</li>)}
    </ul>
  ) : (
    <p class="mt-3 text-sm text-utility-2">No linked insights are configured for this page yet.</p>
  )}
</section>
