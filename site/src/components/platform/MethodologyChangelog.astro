---
interface Props {
  version: string;
  entries: Array<{ version: string; note: string }>;
}

const { version, entries } = Astro.props;
---

<section class="platform-card rounded-xl p-5">
  <h2 class="font-serif text-xl text-brand-white">Methodology changelog</h2>
  <p class="mt-2 text-sm text-utility-2">Current version: {version}</p>
  <ul class="mt-3 space-y-2 text-sm text-utility-2">
    {entries.map((entry) => <li>• {entry.version}: {entry.note}</li>)}
  </ul>
</section>
