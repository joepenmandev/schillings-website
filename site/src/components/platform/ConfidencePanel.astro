---
interface Props {
  confidence: 'low' | 'moderate' | 'high';
  assumptions: string[];
}

const { confidence, assumptions } = Astro.props;
---

<section class="platform-card rounded-xl p-5">
  <h2 class="font-serif text-xl text-brand-white">Confidence panel</h2>
  <p class="mt-2 text-sm text-utility-2">Current confidence: {confidence}</p>
  <ul class="mt-3 space-y-2 text-sm text-utility-2">
    {assumptions.map((assumption) => <li>• {assumption}</li>)}
  </ul>
</section>
