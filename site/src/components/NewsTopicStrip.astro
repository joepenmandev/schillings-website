---
/**
 * Editorial “theme” strip for News & Insights — links to capability hubs (not article filters).
 * Aligns with DESIGN-REFERENCES.md taxonomy vocabulary without requiring per-article topic tags yet.
 */
import type { Locale } from '../i18n/config';
import { localeHref } from '../lib/site-nav';
import { NEWS_THEME_LINKS } from '../lib/news-topics';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<nav
  class="mt-8 border-t border-secondary-2/25 pt-8"
  aria-labelledby="news-themes-heading"
>
  <h2 id="news-themes-heading" class="sr-only">Explore related capabilities</h2>
  <p class="text-[0.65rem] font-medium uppercase tracking-[0.18em] text-secondary-2">Related capabilities</p>
  <ul class="mt-3 flex flex-wrap gap-2">
    {
      NEWS_THEME_LINKS.map(({ label, expertiseId }) => (
        <li>
          <a
            href={localeHref(locale, `services/${expertiseId}`)}
            class="rounded-full border border-secondary-2/40 bg-brand-white px-3 py-1.5 text-xs font-normal text-secondary-4 transition-colors hover:border-secondary-3 hover:bg-utility-2/60 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary-4"
          >
            {label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
