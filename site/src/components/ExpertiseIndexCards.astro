---
import HubLinkCard from '@/components/HubLinkCard.astro';
import { getServicesIndexPublicExpertiseCards } from '@/data/strategic-rebuild-content';
import type { Locale } from '@/i18n/config';
import { expertisePathSlug } from '@/lib/expertise-paths';
import { EXPERTISE_PUBLIC_SEGMENT, localeHref } from '@/lib/site-nav';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const cards = getServicesIndexPublicExpertiseCards();

const staticCardClass =
  'flex min-h-[8.5rem] flex-col rounded-sm border border-secondary-2/20 bg-utility-1/90 px-5 py-5 md:min-h-0 md:px-6 md:py-6';
---

<ul class="mt-8 grid list-none gap-4 sm:grid-cols-2 lg:grid-cols-3 lg:gap-5" aria-label="Expertise areas">
  {
    cards.map((card) => {
      const hub = card.linkedExpertiseId;
      return (
        <li>
          {hub ? (
            <HubLinkCard href={localeHref(locale, `${EXPERTISE_PUBLIC_SEGMENT}/${expertisePathSlug(hub)}`)}>
              <span slot="title">{card.label}</span>
              <span slot="description">Related people and work</span>
            </HubLinkCard>
          ) : (
            <div class={staticCardClass}>
              <span class="font-serif text-lg font-extralight text-secondary-4 md:text-xl">{card.label}</span>
            </div>
          )}
        </li>
      );
    })
  }
</ul>
