---
import type { Locale } from '@/i18n/config';
import type { NewsArticle } from '@/data/news';
import { getRelatedNewsByArticleAuthors } from '@/data/news';
import NewsEditorialCarousel from '@/components/NewsEditorialCarousel.astro';
import { latestPostsByAuthorsSectionTitle, newsListAuthorEntries } from '@/lib/news-list-authors';

interface Props {
  locale: Locale;
  article: NewsArticle;
  /** Max carousel cards */
  limit?: number;
}

const { locale, article, limit = 12 } = Astro.props;

const related = getRelatedNewsByArticleAuthors(article, limit);
const authorEntries = newsListAuthorEntries(article);
const sectionTitle = latestPostsByAuthorsSectionTitle(authorEntries);
---

{
  related.length > 0 ? (
    <section class="latest-posts-by-authors mt-14 border-t border-secondary-2/25 pt-12" aria-labelledby="article-latest-posts-heading">
      <h2 id="article-latest-posts-heading" class="font-serif text-2xl font-normal text-secondary-4 md:text-[1.75rem]">
        {sectionTitle}
      </h2>
      <p class="mt-2 max-w-2xl text-pretty text-sm text-secondary-3">
        More analysis and commentary from the same credited author{authorEntries.length > 1 ? 's' : ''}.
      </p>
      <NewsEditorialCarousel {locale} articles={related} showTopicBadges={false} showAuthorByline={true} class="mt-6 border-0 pt-0" />
    </section>
  ) : null
}
