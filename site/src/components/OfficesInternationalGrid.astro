---
import type { Locale } from '../i18n/config';
import { allOffices } from '../lib/offices';
import { localeHref } from '../lib/site-nav';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const offices = allOffices();
---

<section class="mt-14 border-t border-secondary-2/20 pt-12" aria-labelledby="offices-heading">
  <h2 id="offices-heading" class="text-2xl font-extralight tracking-tight text-secondary-4 md:text-3xl">
    Offices
  </h2>
  <p class="mt-3 max-w-2xl text-pretty text-secondary-3">
    London, Miami, and Dublin — each page includes address, map, phone, email, and an enquiry form with the matching region pre-selected (you can change it in the form).
  </p>
  <ul class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      offices.map((o) => (
        <li>
          <a
            href={localeHref(locale, o.slug)}
            class="flex h-full flex-col rounded-lg border border-secondary-2/25 bg-utility-2/40 p-6 transition-colors hover:border-secondary-3 hover:bg-utility-2/70"
          >
            <span class="font-serif text-xl text-secondary-4">{o.name}</span>
            <span class="mt-3 grow text-sm leading-relaxed text-secondary-3">{o.addressLines.join(' · ')}</span>
            <span class="mt-5 text-sm font-medium text-secondary-4">Contact this office →</span>
          </a>
        </li>
      ))
    }
  </ul>
</section>
