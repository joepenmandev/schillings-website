---
import { inferSchillingsEmailFromSlug } from '../lib/person-email-infer';

export interface Props {
  slug: string;
  sameAs: string[];
  /** When set, used instead of slug-based inference. */
  email?: string;
  tone?: 'default' | 'quiet' | 'admin';
}

const { slug, sameAs, email: emailProp, tone = 'default' } = Astro.props;
const inferred = inferSchillingsEmailFromSlug(slug);
const email = emailProp?.trim() || inferred;
const linkedIn = sameAs.find((u) => /linkedin\.com\/in\//i.test(u));
const twitterOrX = sameAs.find((u) =>
  /^https?:\/\/(www\.)?(twitter\.com|x\.com)\//i.test(u.trim()),
);
if (!email && !linkedIn && !twitterOrX) return null;

const wrapClass =
  tone === 'admin'
    ? 'not-prose flex flex-wrap items-baseline gap-x-[0.9375rem] gap-y-[0.3125rem] pt-[0.8125rem] font-[system-ui,sans-serif] text-[0.6875rem] font-normal leading-[1.48] text-secondary-3/[0.72] md:gap-x-[1.0625rem] md:pt-[1.0625rem]'
    : tone === 'quiet'
      ? 'not-prose mt-10 flex flex-wrap items-center gap-x-6 gap-y-3 border-t border-secondary-2/[0.1] pt-9 font-serif text-[0.9375rem] font-extralight text-secondary-3'
      : 'not-prose mt-12 flex flex-wrap items-center gap-x-7 gap-y-4 border-t border-secondary-2/20 pt-10 font-serif text-base font-normal text-brand-black';

const mailClass =
  tone === 'admin'
    ? 'break-all text-secondary-3/[0.76] no-underline decoration-secondary-2/10 underline-offset-[0.12em] hover:underline hover:decoration-secondary-2/18'
    : tone === 'quiet'
      ? 'break-all text-secondary-3 no-underline decoration-secondary-2/25 underline-offset-[0.2em] transition-[color,text-decoration-color] hover:text-secondary-3 hover:underline hover:decoration-secondary-2/45'
      : 'break-all underline decoration-secondary-2/50 underline-offset-4 transition-colors hover:decoration-secondary-4';

const socialClass =
  tone === 'admin'
    ? 'inline-flex shrink-0 items-center justify-center border border-secondary-2/[0.07] bg-transparent p-[0.25rem] text-secondary-3/58 hover:border-secondary-2/12 hover:bg-utility-2/15'
    : tone === 'quiet'
      ? 'inline-flex shrink-0 items-center justify-center border border-secondary-2/22 bg-transparent p-1.5 text-secondary-4 transition-colors hover:border-secondary-2/35 hover:bg-utility-2/40'
      : 'inline-flex shrink-0 items-center justify-center rounded border border-brand-black/15 bg-brand-black p-1.5 text-brand-white transition-opacity hover:opacity-85';
---

<div class={wrapClass} aria-label="Contact and profiles">
  {
    email ? (
      <a class={mailClass} href={`mailto:${email}`}>
        {email}
      </a>
    ) : null
  }
  <div class="flex shrink-0 flex-wrap items-center gap-2" aria-label="Social profiles">
    {
      linkedIn ? (
        <a
          href={linkedIn}
          rel="noopener noreferrer"
          target="_blank"
          class={socialClass}
          aria-label="LinkedIn profile (opens in new tab)"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
        </a>
      ) : null
    }
    {
      twitterOrX ? (
        <a
          href={twitterOrX}
          rel="noopener noreferrer"
          target="_blank"
          class={socialClass}
          aria-label="X (Twitter) profile (opens in new tab)"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
        </a>
      ) : null
    }
  </div>
</div>
