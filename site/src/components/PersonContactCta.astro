---
import type { Locale } from '../i18n/config';
import { contactSegment, localeHref } from '../lib/site-nav';

interface Props {
  locale: Locale;
  personName: string;
}

const { locale, personName } = Astro.props;
const href = localeHref(locale, contactSegment);
---

<section
  class="mt-10 rounded-xl border border-secondary-2/20 bg-utility-2/45 p-6 shadow-sm ring-1 ring-black/[0.02] md:p-7"
  aria-labelledby="person-contact-cta-heading"
>
  <h2 id="person-contact-cta-heading" class="text-sm font-medium uppercase tracking-wide text-secondary-2">
    Discuss a matter
  </h2>
  <p class="mt-2 text-pretty text-sm leading-relaxed text-secondary-3">
    To explore whether Schillings can help, start on our contact page. Nothing on this profile constitutes legal advice or a client relationship until
    terms are agreed.
  </p>
  <a
    href={href}
    class="mt-5 inline-flex rounded-lg border border-secondary-4 bg-secondary-4 px-5 py-3 text-sm font-medium text-brand-white shadow-sm transition-[opacity,box-shadow] hover:opacity-90 hover:shadow-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary-4"
  >
    Contact Schillings
    <span class="sr-only"> — continue regarding {personName}</span>
  </a>
</section>
