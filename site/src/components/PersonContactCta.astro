---
import type { Locale } from '../i18n/config';
import { contactSegment, localeHref } from '../lib/site-nav';

interface Props {
  locale: Locale;
  personName: string;
}

const { locale, personName } = Astro.props;
const href = localeHref(locale, contactSegment);

const boxClass =
  'mt-12 rounded-xl border border-secondary-2/[0.12] bg-utility-2/40 p-6 shadow-sm ring-1 ring-black/[0.02] md:mt-14 md:p-7';

const headingClass = 'text-sm font-medium uppercase tracking-wide text-secondary-2';

const bodyClass = 'mt-2 text-pretty text-sm leading-relaxed text-secondary-3';

const btnClass =
  'mt-5 inline-flex rounded-lg border border-secondary-4 bg-secondary-4 px-5 py-3 text-sm font-medium text-brand-white shadow-sm transition-[opacity,box-shadow] hover:opacity-90 hover:shadow-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary-4';
---

<section class={boxClass} aria-labelledby="person-contact-cta-heading">
  <h2 id="person-contact-cta-heading" class={headingClass}>Confidential enquiry</h2>
  <p class={bodyClass}>
    To explore whether Schillings can help in confidence, use our contact page. Nothing on this profile constitutes legal
    advice or a client relationship until terms are agreed.
  </p>
  <a href={href} class={btnClass}>
    Speak confidentially
    <span class="sr-only"> — continue regarding {personName}</span>
  </a>
</section>
