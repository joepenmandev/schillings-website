---
import { isCurrentCrumb, type BreadcrumbCrumb } from './page-breadcrumbs-types';

interface Props {
  items: BreadcrumbCrumb[];
  class?: string;
}

const { items, class: className } = Astro.props;
---

<nav class:list={['text-sm text-secondary-3', className]} aria-label="Breadcrumb">
  <ol class="flex flex-wrap items-center gap-x-2 gap-y-1">
    {
      items.map((item, i) => (
        <li class:list={[i > 0 && 'flex items-center gap-x-2']}>
          {i > 0 ? <span class="text-secondary-2/90" aria-hidden="true">/</span> : null}
          {isCurrentCrumb(item) ? (
            <span class="font-medium text-secondary-4" aria-current="page">
              {item.name}
            </span>
          ) : (
            <a
              href={item.href}
              class="font-medium text-secondary-4 underline decoration-secondary-2/40 underline-offset-[0.15em] transition-colors hover:text-secondary-3"
            >
              {item.name}
            </a>
          )}
        </li>
      ))
    }
  </ol>
</nav>
