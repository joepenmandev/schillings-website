---
/**
 * Shared shell for strategic IA hub placeholders: situations, what-we-protect, response-system.
 * Content and lists come from `getStrategicHubPageModel` in `strategic-rebuild-content.ts`.
 */
import type { Locale } from '@/i18n/config';
import Base from '@/layouts/Base.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import DocumentMain from '@/components/DocumentMain.astro';
import { contactSegment, localeHref } from '@/lib/site-nav';
import {
  getStrategicHubPageModel,
  type StrategicHubSegment,
} from '@/data/strategic-rebuild-content';
import { buildJsonLdGraph, buildPageEntityJsonLd } from '@/lib/jsonld-page';

interface Props {
  locale: Locale;
  segment: StrategicHubSegment;
}

const { locale, segment } = Astro.props;
const model = getStrategicHubPageModel(segment);
const origin = Astro.site?.origin ?? Astro.url.origin;
const jsonLd = buildJsonLdGraph(
  buildPageEntityJsonLd({
    origin,
    locale,
    pathSegment: segment,
    pageType: 'WebPage',
    name: model.title,
    description: model.metaDescription,
  }),
);
const contactHref = localeHref(locale, contactSegment);
---

<Base title={model.title} description={model.metaDescription} {locale} pathAfterLocale={segment}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <SiteHeader {locale} />
  <DocumentMain>
    <article>
      <p class="text-xs font-medium uppercase tracking-[0.18em] text-secondary-2">Schillings</p>
      <h1 class="mt-3 text-pretty text-3xl font-extralight leading-tight tracking-tight text-secondary-4 md:text-[3.125rem] md:leading-[1.1]">
        {model.heading}
      </h1>
      <p class="mt-6 text-pretty text-base font-normal leading-relaxed text-secondary-3 md:text-[1.05rem] md:leading-[1.65]">
        {model.intro}
      </p>

      <section
        class="mt-10 rounded-lg border border-secondary-2/15 bg-utility-1/90 px-4 py-8 sm:px-8 md:mt-12 md:px-10 md:py-10"
        aria-labelledby={`hub-list-${segment}`}
      >
        <h2 id={`hub-list-${segment}`} class="text-xs font-medium uppercase tracking-[0.18em] text-secondary-2">
          {model.listHeading}
        </h2>
        <ul class="mt-6 grid list-none gap-x-10 gap-y-3 sm:grid-cols-2">
          {
            model.listItems.map((item) => (
              <li class="text-pretty text-sm font-normal leading-snug text-secondary-3 md:text-base md:leading-relaxed">
                <span class="font-medium text-secondary-4">{item.primary}</span>
                {item.secondary ? (
                  <span class="text-secondary-3"> — {item.secondary}</span>
                ) : null}
              </li>
            ))
          }
        </ul>
      </section>

      <p class="mt-10 max-w-2xl text-pretty text-sm leading-relaxed text-secondary-3 md:mt-12 md:text-base">
        To discuss a matter in confidence,
        <a
          href={contactHref}
          class="font-medium text-secondary-4 underline decoration-secondary-2/45 underline-offset-[0.15em] transition-colors hover:decoration-secondary-4"
        >
          contact Schillings
        </a>
        .
      </p>
    </article>
  </DocumentMain>
</Base>
