---
/**
 * Featured lead story on news index — same structural tokens as NewsArticlePostHero (accent stack, author row, footer).
 */
import type { Locale } from '@/i18n/config';
import type { NewsArticle } from '@/data/news';
import { publicContactEmailForPersonSlug } from '@/data/people';
import { articleDatePublishedIso } from '@/lib/news-datetime';
import { newsListAuthorEntries } from '@/lib/news-list-authors';
import { formatNewsCardDateUk, newsExcerpt, newsHeroAlt, newsHeroDisplaySrc } from '@/lib/news-render';
import { topicSlugFromLabel } from '@/lib/news-topic-slug';
import { localeHref } from '@/lib/site-nav';
import NewsBookOpenGutter from '@/components/NewsBookOpenGutter.astro';

interface Props {
  locale: Locale;
  article: NewsArticle;
  showTopicBadges?: boolean;
}

const { locale, article, showTopicBadges = true } = Astro.props;

const articleHref = localeHref(locale, `news/${article.slug}`);
const cardDate = formatNewsCardDateUk(article);
const rawHero = newsHeroDisplaySrc(article)?.trim();
const heroSrc =
  rawHero && !rawHero.startsWith('http')
    ? rawHero.startsWith('/')
      ? rawHero
      : `/${rawHero}`
    : rawHero;
const heroAlt = newsHeroAlt(article) || article.title;
const authorEntries = newsListAuthorEntries(article);
const topics = article.topics?.filter((t) => t.trim()) ?? [];
const lede = newsExcerpt(article, 280);
const homeHref = localeHref(locale, '');
---

<article
  class="news-archive-featured book-hero-motion overflow-hidden rounded-lg border border-secondary-2/25 shadow-md ring-1 ring-secondary-4/[0.08] transition-shadow duration-500 ease-out hover:shadow-2xl hover:ring-secondary-2/25 md:rounded-xl md:shadow-lg"
  aria-labelledby={`news-featured-title-${article.slug}`}
>
  <div
    class="grid min-w-0 grid-cols-1 md:grid-cols-[minmax(0,1fr)_6px_minmax(0,1fr)] md:items-stretch"
  >
    <div
      class="order-3 flex h-full min-h-0 flex-col gap-5 border-l border-secondary-2/20 bg-[linear-gradient(168deg,#faf9f6_0%,#f4f1eb_42%,#ebe6dc_100%)] px-6 py-6 shadow-[inset_8px_0_18px_-10px_rgba(45,1,43,0.07)] md:order-1 md:gap-6 md:px-9 md:py-8 lg:px-11 lg:py-9"
    >
      <div class="min-w-0">
        <div class="flex gap-3.5">
          <span
            class="mt-1 min-h-[3.25rem] w-[3px] shrink-0 self-stretch rounded-full bg-gradient-to-b from-secondary-3/60 via-secondary-4/50 to-secondary-3/35"
            aria-hidden="true"
          />
          <div class="min-w-0 flex-1">
            <p class="text-[0.6rem] font-medium uppercase tracking-[0.22em] text-secondary-3/80">Featured insight</p>
            {
              cardDate ? (
                <p class="mt-2 text-xs font-normal tracking-wide text-secondary-3">
                  <time datetime={articleDatePublishedIso(article)}>{cardDate}</time>
                </p>
              ) : null
            }
            <h2
              id={`news-featured-title-${article.slug}`}
              class:list={[
                'font-serif text-[1.65rem] font-normal leading-[1.15] tracking-tight text-[#3c3b39] sm:text-[2rem] lg:text-[2.2rem]',
                cardDate ? 'mt-3' : 'mt-2',
              ]}
            >
              <a
                href={articleHref}
                class="text-inherit decoration-secondary-2/40 underline-offset-[0.15em] transition-colors hover:text-secondary-3 hover:decoration-secondary-3"
              >
                {article.title}
              </a>
            </h2>
          </div>
        </div>

        {
          showTopicBadges && topics.length > 0 ? (
            <ul class="mt-5 flex flex-wrap gap-x-4 gap-y-2 border-b border-secondary-2/25 pb-6 font-serif text-sm text-secondary-3" aria-label="Topics">
              {topics.map((t) => (
                <li>
                  <a
                    href={localeHref(locale, `news/topic/${topicSlugFromLabel(t)}`)}
                    class="underline decoration-secondary-2/50 underline-offset-4 transition-colors hover:text-secondary-4 hover:decoration-secondary-3"
                  >
                    {t}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <div class="mt-5 border-b border-secondary-2/25 pb-6" aria-hidden="true" />
          )
        }

        {lede ? <p class="mt-4 max-w-2xl text-pretty text-sm leading-relaxed text-secondary-3 md:text-base">{lede}</p> : null}
      </div>

      <div class="author-details space-y-5 border-t border-secondary-2/30 pt-4 md:space-y-6 md:pt-5">
        {
          authorEntries.length > 0 ? (
            authorEntries.map((entry) =>
              entry.type === 'credit' ? (
                <div class="flex gap-4">
                  <div class="flex min-w-0 flex-1 flex-col justify-center">
                    <p class="font-serif text-base italic text-secondary-4">By {entry.name}</p>
                    <p class="mt-1 text-xs text-secondary-3">Schillings</p>
                  </div>
                </div>
              ) : (
                (() => {
                  const email = publicContactEmailForPersonSlug(entry.slug);
                  const img = entry.imagePath;
                  return (
                    <div class="flex gap-3 sm:gap-4">
                      {img ? (
                        <a
                          href={localeHref(locale, `people/${entry.slug}`)}
                          class="shrink-0 self-start rounded-full ring-2 ring-brand-white shadow-md ring-offset-2 ring-offset-[#f0ebe3] transition hover:ring-secondary-3"
                          aria-label={`${entry.name} — profile`}
                        >
                          <img
                            src={img}
                            alt=""
                            width="64"
                            height="64"
                            loading="lazy"
                            decoding="async"
                            class="h-14 w-14 rounded-full object-cover sm:h-16 sm:w-16"
                          />
                        </a>
                      ) : (
                        <span
                          class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full border border-secondary-2/35 bg-brand-white font-serif text-base text-secondary-4 sm:h-16 sm:w-16"
                          aria-hidden="true"
                        >
                          {entry.name
                            .split(/\s+/)
                            .filter(Boolean)
                            .slice(0, 2)
                            .map((w) => w[0]?.toUpperCase() ?? '')
                            .join('')}
                        </span>
                      )}
                      <div class="min-w-0 flex-1">
                        {email ? (
                          <p class="text-[0.7rem] leading-snug text-secondary-3 sm:text-xs">
                            <a href={`mailto:${email}`} class="underline decoration-secondary-2/40 underline-offset-2 hover:text-secondary-4">
                              {email}
                            </a>
                          </p>
                        ) : null}
                        <p class:list={[email ? 'mt-1' : '', 'font-serif text-base font-normal leading-snug text-secondary-4 sm:text-lg']}>
                          <a
                            href={localeHref(locale, `people/${entry.slug}`)}
                            class="underline decoration-secondary-2/35 underline-offset-[0.15em] transition-colors hover:decoration-secondary-4"
                          >
                            {entry.name}
                          </a>
                        </p>
                        <p class="mt-0.5 text-[0.7rem] font-normal leading-snug text-secondary-3 sm:text-xs">{entry.role}</p>
                      </div>
                    </div>
                  );
                })(),
              ),
            )
          ) : null
        }
      </div>

      <div class="mt-auto flex flex-wrap items-center justify-between gap-3 border-t border-secondary-2/20 pt-3 md:gap-4 md:pt-4">
        <a
          href={homeHref}
          class="font-sans text-[0.5rem] font-semibold uppercase tracking-[0.32em] text-secondary-2/85 transition-colors hover:text-secondary-3"
        >
          Schillings
        </a>
        <a
          href={articleHref}
          class="inline-flex shrink-0 items-center gap-1.5 rounded-sm bg-secondary-4 px-4 py-2.5 text-xs font-medium tracking-wide text-brand-white transition hover:bg-secondary-3 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary-4"
        >
          Read more
          <span aria-hidden="true" class="text-sm leading-none">
            ↗
          </span>
        </a>
      </div>
    </div>

    <NewsBookOpenGutter />

    <div
      class="post-main-image group/img relative order-1 min-h-[12rem] overflow-hidden border-r border-secondary-2/15 bg-secondary-4 shadow-[inset_-12px_0_20px_-14px_rgba(0,0,0,0.2)] md:order-3 md:min-h-[min(20rem,38vh)] lg:min-h-[min(24rem,42vh)]"
    >
      <a
        href={articleHref}
        class="relative block h-full min-h-[inherit] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary-4"
        aria-label={`Read article: ${article.title}`}
      >
        <span
          class="pointer-events-none absolute inset-y-0 left-0 z-[1] w-8 bg-gradient-to-r from-[#f4f1eb]/50 to-transparent md:w-12"
          aria-hidden="true"
        />
        <div
          class="absolute inset-0 z-0 flex items-center justify-center bg-gradient-to-br from-secondary-4 via-secondary-3/80 to-primary-1/40"
          aria-hidden="true"
        >
          <span class="font-serif text-5xl font-extralight text-utility-1/40">{article.title.trim().charAt(0) || '—'}</span>
        </div>
        {
          heroSrc ? (
            <img
              src={heroSrc}
              alt={heroAlt}
              width="800"
              height="800"
              class="relative z-10 h-full min-h-[12rem] w-full object-cover motion-safe:transition-transform motion-safe:duration-700 motion-safe:ease-out motion-safe:group-hover/img:scale-[1.04] md:min-h-[min(20rem,38vh)] lg:min-h-[min(24rem,42vh)]"
              loading="eager"
              decoding="async"
              fetchpriority="high"
              onerror="this.remove()"
            />
          ) : null
        }
      </a>
    </div>
  </div>
</article>
