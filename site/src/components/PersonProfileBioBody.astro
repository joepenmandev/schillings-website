---
import PersonTrustSignals from '@/components/PersonTrustSignals.astro';
import type { PersonRecognition } from '@/data/people';

interface Props {
  personName: string;
  sameAs: string[];
  recognitions: PersonRecognition[];
  hideRecognitionBadgeBlock: boolean;
  usePhase2ProofAdjacency: boolean;
  /** Number of biography paragraphs placed in the hero (Phase 2 trust follows hero when &gt; 0). */
  heroLeadCount: number;
  bioParas: string[];
}

const {
  personName,
  sameAs,
  recognitions,
  hideRecognitionBadgeBlock,
  usePhase2ProofAdjacency,
  heroLeadCount,
  bioParas,
} = Astro.props;

const bioTextClass =
  'text-pretty text-base font-normal leading-[1.65] text-secondary-3 md:text-[1.05rem]';
---

<div class="mt-5 space-y-5 md:mt-6 md:space-y-6">
  {
    usePhase2ProofAdjacency && heroLeadCount > 0 ? (
      <>
        <PersonTrustSignals
          personName={personName}
          sameAs={sameAs}
          recognitions={recognitions}
          hideLinkedIn
          hideRecognitionBadges={hideRecognitionBadgeBlock}
        />
        {bioParas.map((para) => (
          <p class={bioTextClass}>{para}</p>
        ))}
      </>
    ) : usePhase2ProofAdjacency ? (
      <>
        {bioParas[0] ? <p class={bioTextClass}>{bioParas[0]}</p> : null}
        <PersonTrustSignals
          personName={personName}
          sameAs={sameAs}
          recognitions={recognitions}
          hideLinkedIn
          hideRecognitionBadges={hideRecognitionBadgeBlock}
        />
        {bioParas.slice(1).map((para) => (
          <p class={bioTextClass}>{para}</p>
        ))}
      </>
    ) : (
      bioParas.map((para) => <p class={bioTextClass}>{para}</p>)
    )
  }
</div>
