---
import type { Locale } from '@/i18n/config';
import type { NewsArticle } from '@/data/news';
import NewsArticleEditorialCard from '@/components/NewsArticleEditorialCard.astro';

interface Props {
  locale: Locale;
  articles: NewsArticle[];
  showTopicBadges?: boolean;
  showAuthorByline?: boolean;
  excludeAuthorSlugs?: string[];
  class?: string;
}

const {
  locale,
  articles,
  showTopicBadges = false,
  showAuthorByline = true,
  excludeAuthorSlugs = [],
  class: className = '',
} = Astro.props;
---

{
  articles.length > 0 ? (
    <div class:list={['news-article-grid', className]}>
      <ul class="grid list-none grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
        {articles.map((article, index) => (
          <li class="min-w-0">
            <NewsArticleEditorialCard
              {locale}
              {article}
              {index}
              {showTopicBadges}
              {showAuthorByline}
              excludeAuthorSlugs={excludeAuthorSlugs}
              class="h-full"
            />
          </li>
        ))}
      </ul>
    </div>
  ) : null
}
