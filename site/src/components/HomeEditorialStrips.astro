---
/**
 * Outcome headline pairs — legacy homepage reference copy (no Lorem).
 */
const lightBand = [
  { line1: 'Personal privacy,', line2: 'assured.' },
  { line1: 'Fake news,', line2: 'corrected.' },
  { line1: 'Unfair accusations,', line2: 'rebutted.' },
  { line1: 'Strongest positions,', line2: 'established.' },
] as const;

const darkBand = [
  { line1: 'Hostile action,', line2: 'countered.' },
  { line1: 'Complex situations,', line2: 'navigated.' },
] as const;
---

<section class="border-t border-secondary-2/20 bg-utility-1 px-[min(1.25rem,5.5vw)] py-16 md:px-[min(5rem,5.5vw)] md:py-24">
  <div class="mx-auto grid max-w-6xl gap-14 md:grid-cols-2 md:gap-x-16 md:gap-y-20">
    {
      lightBand.map(({ line1, line2 }) => (
        <div class="text-left">
          <p class="font-serif text-[clamp(1.75rem,3.5vw,2.5rem)] font-extralight leading-tight tracking-tight text-secondary-4">
            {line1}
          </p>
          <p class="mt-1 font-serif text-[clamp(1.75rem,3.5vw,2.5rem)] font-extralight italic leading-tight tracking-tight text-secondary-3">
            {line2}
          </p>
        </div>
      ))
    }
  </div>
</section>

<section class="bg-secondary-4 px-[min(1.25rem,5.5vw)] py-16 text-brand-white md:px-[min(5rem,5.5vw)] md:py-24">
  <div class="mx-auto grid max-w-6xl gap-14 md:grid-cols-2 md:gap-x-16 md:gap-y-20">
    {
      darkBand.map(({ line1, line2 }) => (
        <div class="text-left">
          <p class="font-serif text-[clamp(1.75rem,3.5vw,2.5rem)] font-extralight leading-tight tracking-tight text-brand-white/95">
            {line1}
          </p>
          <p class="mt-1 font-serif text-[clamp(1.75rem,3.5vw,2.5rem)] font-extralight italic leading-tight tracking-tight text-secondary-2">
            {line2}
          </p>
        </div>
      ))
    }
  </div>
</section>
