---
/**
 * Benchmark-inspired recognition row: high-read institutional proof without badge chrome.
 * Uses the same ordering and outbound rules as trust badges.
 */
import type { PersonRecognition } from '@/data/people';
import { resolveRecognitionOutboundHref } from '@/lib/person-recognition-href';
import { recognitionDirectoryLine, sortPersonRecognitions } from '@/lib/person-recognition-meta';

interface Props {
  items: PersonRecognition[];
}

const { items } = Astro.props;
const sorted = sortPersonRecognitions(items);

const kickerClass = 'text-[11px] font-medium uppercase tracking-wider text-secondary-2/90';
const titleClass = 'text-sm font-medium leading-snug text-secondary-4';
const metaClass = 'mt-1 text-xs leading-snug text-secondary-3/90';
const cellClass =
  'border-b border-secondary-2/[0.08] py-4 last:border-b-0 sm:border-b-0 sm:py-0 md:border-0 md:py-0';
const focusRing =
  'rounded-sm outline-none focus-visible:ring-2 focus-visible:ring-secondary-3/50 focus-visible:ring-offset-2 focus-visible:ring-offset-utility-1';
---

{
  sorted.length > 0 ? (
    <section class="not-prose border-b border-secondary-2/[0.1] pb-6 md:pb-7" aria-label="Independent directory recognitions">
      <div class="flex flex-col gap-6 md:flex-row md:items-start md:gap-8 lg:gap-10">
        <p class:list={[kickerClass, 'max-w-[14rem] shrink-0 md:pt-0.5']}>Recognised by leading directories</p>
        <div class="grid min-w-0 flex-1 grid-cols-1 gap-y-5 sm:grid-cols-2 sm:gap-x-8 sm:gap-y-6 lg:grid-cols-4 lg:gap-x-6 xl:gap-x-8">
          {sorted.map((item) => {
            const href = resolveRecognitionOutboundHref(item);
            const meta = recognitionDirectoryLine(item);
            const inner = (
              <>
                <p class={titleClass}>{item.title}</p>
                {meta ? <p class={metaClass}>{meta}</p> : null}
              </>
            );
            return (
              <div class:list={[cellClass, 'sm:pb-0']}>
                {href ? (
                  <a href={href} rel="noopener noreferrer" target="_blank" class:list={[focusRing, 'block']}>
                    {inner}
                    <span class="sr-only"> (opens in new tab)</span>
                  </a>
                ) : (
                  <div>{inner}</div>
                )}
              </div>
            );
          })}
        </div>
      </div>
    </section>
  ) : null
}
