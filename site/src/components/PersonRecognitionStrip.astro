---
/**
 * Full-width recognition row below the hero grid only (never inside the portrait grid).
 */
import type { PersonRecognition } from '@/data/people';
import { resolveRecognitionOutboundHref } from '@/lib/person-recognition-href';
import { recognitionDirectoryLine, sortPersonRecognitions } from '@/lib/person-recognition-meta';

interface Props {
  items: PersonRecognition[];
}

const { items } = Astro.props;
const sorted = sortPersonRecognitions(items);

/** Recognition band: first column anchor + directory cells — typography-led, minimal chrome. */
const kickerClass =
  'text-[11px] font-semibold uppercase leading-snug tracking-[0.14em] text-secondary-4';
const titleClass = 'text-[0.8125rem] font-semibold leading-snug tracking-tight text-secondary-4';
const metaClass = 'mt-1.5 text-[0.6875rem] font-normal leading-snug text-secondary-3/95';
const focusRing =
  'rounded-sm outline-none focus-visible:ring-2 focus-visible:ring-secondary-3/50 focus-visible:ring-offset-2 focus-visible:ring-offset-utility-1';

const directoryGlyphClass = 'mt-0.5 h-8 w-8 shrink-0 text-secondary-4/55';
---

{
  sorted.length > 0 ? (
    <section class="not-prose border-b border-secondary-2/15 bg-utility-2/20 pb-7 pt-0 md:pb-8" aria-label="Independent directory recognitions">
      <div class="flex flex-col divide-y divide-secondary-2/12 md:flex-row md:items-stretch md:divide-x md:divide-y-0">
        <div class="flex gap-3 border-l-2 border-secondary-4/28 bg-utility-2/35 py-5 pl-4 pr-4 md:max-w-[14.5rem] md:shrink-0 md:flex-col md:justify-center md:py-6 md:pl-5 md:pr-5">
          <svg class={directoryGlyphClass} viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path
              d="M8 6.5h11a2 2 0 0 1 2 2v15a2 2 0 0 1-2 2H8a1.5 1.5 0 0 1-1.5-1.5v-16A1.5 1.5 0 0 1 8 6.5Z"
              stroke="currentColor"
              stroke-width="1.1"
              stroke-linejoin="round"
            />
            <path d="M11 11h6M11 15h6M11 19h4" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" />
          </svg>
          <p class:list={[kickerClass, 'max-w-[12rem] text-pretty']}>Recognised by leading directories</p>
        </div>
        <div class="grid min-w-0 flex-1 grid-cols-1 divide-y divide-secondary-2/12 bg-brand-white/25 sm:grid-cols-2 sm:divide-x sm:divide-y-0 lg:grid-cols-4">
          {sorted.map((item) => {
            const href = resolveRecognitionOutboundHref(item);
            const meta = recognitionDirectoryLine(item);
            const inner = (
              <>
                <p class={titleClass}>{item.title}</p>
                {meta ? <p class={metaClass}>{meta}</p> : null}
              </>
            );
            return (
              <div class="flex min-h-[5.5rem] items-start px-4 py-5 sm:min-h-[5.75rem] sm:px-5 sm:py-5">
                {href ? (
                  <a href={href} rel="noopener noreferrer" target="_blank" class:list={[focusRing, 'block w-full']}>
                    {inner}
                    <span class="sr-only"> (opens in new tab)</span>
                  </a>
                ) : (
                  <div class="w-full">{inner}</div>
                )}
              </div>
            );
          })}
        </div>
      </div>
    </section>
  ) : null
}
