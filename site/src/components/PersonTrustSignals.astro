---
/**
 * Visible E-E-A-T affordances: verified-style outbound links.
 * Recognition badges use `resolveRecognitionOutboundHref`: `scope: firm` → Schillings firm URL for that publisher;
 * `scope: person` → the row’s `href` when set, else the same firm URL (e.g. Chambers with no deep link).
 */
import RecognitionBadges from '@/components/RecognitionBadges.astro';
import type { PersonRecognition } from '@/data/people';
import { schillingsFirmDirectoryHref } from '@/lib/person-recognition-href';

export interface Props {
  personName: string;
  sameAs: string[];
  recognitions?: PersonRecognition[];
  /** When true, omit the LinkedIn block (e.g. already shown in `PersonPublicContact`). */
  hideLinkedIn?: boolean;
  /** When true, omit the recognition badge block (e.g. already shown in institutional standing). */
  hideRecognitionBadges?: boolean;
  /** Shorter compliance line above directory links. */
  complianceTone?: 'standard' | 'quiet';
  /** Plain top border for benchmark profiles; default keeps the contained panel. */
  surface?: 'panel' | 'plain';
  /** Omit opening compliance paragraphs (e.g. already covered above). */
  omitIntro?: boolean;
  /** `index` — caption-style directory links (institutional profiles). */
  directoryStyle?: 'chips' | 'index';
  /** No outer border/margin — nest inside institutional evaluation column. */
  flush?: boolean;
  /** Quieter index typography and spacing for continuous evaluation surfaces. */
  evalSurface?: boolean;
}

const {
  personName,
  sameAs,
  recognitions = [],
  hideLinkedIn = false,
  hideRecognitionBadges = false,
  complianceTone = 'standard',
  surface = 'panel',
  omitIntro = false,
  directoryStyle = 'chips',
  flush = false,
  evalSurface = false,
} = Astro.props;

const surfaceClass = flush
  ? 'border-0 p-0'
  : surface === 'plain' && directoryStyle === 'index'
    ? 'mt-6 border-t border-secondary-2/10 pt-6'
    : surface === 'plain'
      ? 'mt-8 border-t border-secondary-2/20 pt-8'
      : 'mt-10 rounded-xl border border-secondary-2/20 bg-utility-2/45 p-6 shadow-sm ring-1 ring-black/[0.02] md:p-7';

const headingClass =
  directoryStyle === 'index'
    ? evalSurface
      ? 'text-[0.5rem] font-normal uppercase tracking-[0.2em] text-secondary-2/46'
      : 'text-[0.56rem] font-normal uppercase tracking-[0.19em] text-secondary-2/72'
    : 'text-sm font-medium uppercase tracking-wide text-secondary-2';

const indexDirLinkClass = evalSurface
  ? 'text-[0.65rem] font-normal leading-snug text-secondary-3/[0.9] underline decoration-transparent underline-offset-[0.18em] hover:underline hover:decoration-secondary-2/18 focus-visible:outline focus-visible:outline-1 focus-visible:outline-offset-2 focus-visible:outline-secondary-3/35'
  : 'text-[0.68rem] font-normal leading-snug text-secondary-3 no-underline decoration-secondary-2/0 underline-offset-[0.18em] transition-[color,text-decoration-color] hover:text-secondary-3 hover:underline hover:decoration-secondary-2/32';

const indexMetaClass = evalSurface
  ? 'text-[0.56rem] leading-[1.52] text-secondary-2/44'
  : 'text-[0.62rem] leading-[1.5] text-secondary-2/58';

const linkedIn = sameAs.find((u) => /linkedin\.com\/in\//i.test(u));

/** Non-LinkedIn / non-X authoritative URLs (publisher bios, etc.) — LinkedIn & X/Twitter shown in `PersonPublicContact`. */
function otherSameAsUrls(urls: readonly string[]): string[] {
  const seen = new Set<string>();
  const out: string[] = [];
  for (const raw of urls) {
    const u = raw.trim();
    if (!/^https?:\/\//i.test(u)) continue;
    if (/linkedin\.com\/in\//i.test(u)) continue;
    if (/^(https?:\/\/)?(www\.)?(twitter\.com|x\.com)\//i.test(u)) continue;
    if (linkedIn && u === linkedIn) continue;
    if (seen.has(u)) continue;
    seen.add(u);
    out.push(u);
  }
  return out;
}

const extraSameAs = otherSameAsUrls(sameAs);

function externalLinkLabel(url: string): string {
  try {
    return new URL(url).hostname.replace(/^www\./i, '');
  } catch {
    return 'External link';
  }
}

const LEGAL_DIRECTORIES: { label: string; href: string; hint: string }[] = [
  {
    label: 'Chambers and Partners',
    href: schillingsFirmDirectoryHref('chambers') ?? 'https://chambers.com/law-firm/schillings-uk-1:366',
    hint: 'Independent legal directory',
  },
  {
    label: 'The Legal 500',
    href:
      schillingsFirmDirectoryHref('legal500') ??
      'https://www.legal500.com/firms/2987-schillings/r-england/lawyers',
    hint: 'Independent legal directory',
  },
  {
    label: "Spear's",
    href: schillingsFirmDirectoryHref('spears') ?? 'https://www.spears500.com/',
    hint: 'HNW legal and reputation rankings',
  },
];

const linkClass =
  'inline-block rounded border border-secondary-2/35 bg-utility-1 px-3 py-2 text-xs font-medium tracking-wide text-secondary-4 transition-colors hover:border-secondary-3 hover:bg-utility-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary-3/70';

const textLinkClass =
  'inline-flex items-center gap-2 text-sm font-medium text-secondary-4 underline decoration-secondary-2/50 underline-offset-2 transition-colors hover:decoration-secondary-4 focus-visible:rounded focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary-3/70';
---

<aside class:list={[surfaceClass]} aria-labelledby="trust-signals-heading">
  <h2 id="trust-signals-heading" class={headingClass}>
    {
      evalSurface
        ? 'Directories'
        : complianceTone === 'quiet'
          ? 'Independent directories'
          : 'Profiles & independent directories'
    }
  </h2>
  {
    !omitIntro ? (
      <p class:list={['mt-2 text-pretty leading-relaxed', directoryStyle === 'index' ? indexMetaClass : 'text-sm text-secondary-3']}>
        {complianceTone === 'quiet' ? (
          <>
            Third-party listings may help place background in context. Use search on each publisher’s site where
            applicable. Nothing here implies a client relationship or legal advice.
          </>
        ) : (
          <>
            Third-party sources can help readers place professional background in context. Schillings does not control
            external sites or rankings; use firm search or name search on the directories below where applicable. Contact
            Schillings for formal engagements.
          </>
        )}
      </p>
    ) : null
  }
  {
    recognitions.length > 0 && !hideRecognitionBadges ? (
      <div class="mt-5">
        <p class="text-xs font-medium uppercase tracking-wide text-secondary-2">Recognitions</p>
        <p class="mt-2 text-pretty text-xs leading-relaxed text-secondary-3/90">
          Selected third-party listings and rankings for {personName}. Methodologies and criteria are set by each
          publisher.
        </p>
        <div class="mt-3">
          <RecognitionBadges items={recognitions} />
        </div>
      </div>
    ) : null
  }

  {
    linkedIn && !hideLinkedIn ? (
      <div class="mt-5">
        <p class="text-xs font-medium uppercase tracking-wide text-secondary-2">Professional profile</p>
        <a href={linkedIn} class={`mt-2 ${textLinkClass}`} rel="noopener noreferrer" target="_blank">
          {personName} on LinkedIn
          <span class="sr-only"> (opens in new tab)</span>
        </a>
      </div>
    ) : null
  }

  {
    extraSameAs.length > 0 ? (
      <div class="mt-6">
        <p class="text-xs font-medium uppercase tracking-wide text-secondary-2">Additional references</p>
        <ul class="mt-3 flex flex-col gap-2" role="list">
          {extraSameAs.map((href) => (
            <li>
              <a href={href} class={textLinkClass} rel="noopener noreferrer" target="_blank">
                <span class="break-all">{externalLinkLabel(href)}</span>
                <span class="sr-only"> (opens in new tab)</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ) : null
  }

  <nav
    class:list={[directoryStyle === 'index' ? (evalSurface ? 'mt-3' : 'mt-4') : omitIntro ? 'mt-4' : 'mt-6']}
    aria-label="Major legal and reputation directories"
  >
    {
      directoryStyle === 'index' ? (
        <>
          <p class={indexMetaClass}>
            {evalSurface ? 'Listings are maintained by each publisher.' : 'Publisher search — use each site to locate firm or named listings.'}
          </p>
          <ul class:list={['flex flex-col', evalSurface ? 'mt-2.5 gap-y-1' : 'mt-3 gap-y-1.5']} role="list">
            {LEGAL_DIRECTORIES.map((d) => (
              <li>
                <a href={d.href} class={indexDirLinkClass} rel="noopener noreferrer" target="_blank" title={d.hint}>
                  {d.label}
                  <span class="sr-only"> (opens in new tab)</span>
                </a>
              </li>
            ))}
          </ul>
        </>
      ) : (
        <>
          <p class="text-xs font-medium uppercase tracking-wide text-secondary-2">Major legal directories</p>
          <p class="mt-2 text-pretty text-xs leading-relaxed text-secondary-3/90">Use search on each site to find the firm or named individuals.</p>
          <ul class="mt-3 flex flex-wrap gap-2" role="list">
            {LEGAL_DIRECTORIES.map((d) => (
              <li>
                <a href={d.href} class={linkClass} rel="noopener noreferrer" target="_blank" title={d.hint}>
                  {d.label}
                  <span class="sr-only"> (opens in new tab)</span>
                </a>
              </li>
            ))}
          </ul>
        </>
      )
    }
  </nav>
</aside>
