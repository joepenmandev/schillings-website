---
/**
 * Card grid linking to firm situation pages — copy from `SituationDetailModel` only (title + lead).
 */
import type { Locale } from '@/i18n/config';
import type { StrategicSituationId } from '@/data/strategic-rebuild-content';
import { getSituationDetailById, situationPathSlug } from '@/data/strategic-rebuild-content';
import { localeHref } from '@/lib/site-nav';

interface Props {
  locale: Locale;
  situationIds: readonly StrategicSituationId[];
  /** Given name for heading (e.g. first token of `person.name`). */
  givenName: string;
}

const { locale, situationIds, givenName } = Astro.props;
---

{
  situationIds.length > 0 ? (
    <section class="mt-12 max-w-6xl border-b border-secondary-2/20 pb-10 md:mt-14 md:pb-12" aria-labelledby="person-situations-grid-heading">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between sm:gap-4">
        <h2 id="person-situations-grid-heading" class="max-w-xl text-xs font-medium uppercase tracking-wider text-secondary-2">
          Situations {givenName} helps clients manage
        </h2>
        <a
          href={localeHref(locale, 'situations')}
          class="shrink-0 text-xs font-medium text-secondary-4 underline decoration-secondary-2/40 underline-offset-[0.15em] transition-colors hover:decoration-secondary-4"
        >
          View all situations →
        </a>
      </div>
      <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
        {situationIds.map((id) => {
          const d = getSituationDetailById(id);
          const href = localeHref(locale, `situations/${situationPathSlug(id)}`);
          return (
            <article class="border border-secondary-2/15 bg-utility-2/25 p-4">
              <a href={href} class="block outline-none transition-colors hover:border-secondary-3 focus-visible:ring-2 focus-visible:ring-secondary-3/40 focus-visible:ring-offset-2 focus-visible:ring-offset-utility-1">
                <h3 class="text-sm font-medium leading-snug text-secondary-4">{d.title}</h3>
                <p class="mt-2 text-pretty text-xs leading-relaxed text-secondary-3">{d.lead}</p>
                <span class="sr-only"> — view situation</span>
              </a>
            </article>
          );
        })}
      </div>
    </section>
  ) : null
}
