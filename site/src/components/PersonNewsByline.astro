---
import type { Locale } from '../i18n/config';
import type { NewsArticle } from '../data/news';
import NewsEditorialCarousel from '@/components/NewsEditorialCarousel.astro';
import { localeHref } from '../lib/site-nav';

interface Props {
  locale: Locale;
  articles: NewsArticle[];
  /** Max rows to show before “View all news” */
  displayLimit?: number;
  /** Links to `/news/author/{slug}/` (full list of pieces credited to this colleague). */
  personSlug?: string;
  personName?: string;
  /** Institutional profile: quieter editorial scale. */
  layout?: 'default' | 'institutional';
}

const { locale, articles, displayLimit = 8, personSlug, personName, layout = 'default' } = Astro.props;
const visible = articles.slice(0, displayLimit);
const hasMore = articles.length > displayLimit;
const showAuthorArchive = Boolean(personSlug?.trim() && personName?.trim());
const excludeAuthorSlugs = personSlug?.trim() ? [personSlug.trim()] : [];
---

{
  articles.length > 0 ? (
    <section class:list={[layout === 'institutional' ? 'mt-[4.5rem] md:mt-20 lg:mt-[6.25rem] xl:mt-28' : 'mt-10']} aria-labelledby="person-news-heading">
      <h2
        id="person-news-heading"
        class:list={[
          layout === 'institutional'
            ? 'text-[0.52rem] font-normal uppercase tracking-[0.19em] text-secondary-2/58'
            : 'text-sm font-medium uppercase tracking-wide text-secondary-2',
        ]}
      >
        Related Intelligence
      </h2>
      <p
        class:list={[
          'max-w-2xl text-pretty leading-relaxed',
          layout === 'institutional' ? 'mt-3 text-[0.8125rem] font-extralight text-secondary-3 md:mt-[0.95rem]' : 'mt-2 text-sm text-secondary-3',
        ]}
      >
        Published analysis and commentary where this colleague is credited as an author — useful context on perspective
        and public commentary. Co-authors appear on each card with a short role line linking to their profiles.
      </p>
      <div
        class:list={[
          layout === 'institutional' ? 'mt-6 border-t border-secondary-2/[0.05] pt-6' : 'mt-6 border-t border-secondary-2/20 pt-4',
        ]}
      >
        <NewsEditorialCarousel
          {locale}
          articles={visible}
          showTopicBadges={false}
          showAuthorByline={true}
          {excludeAuthorSlugs}
        />
      </div>
      {showAuthorArchive ? (
        <p class="mt-5">
          <a
            href={localeHref(locale, `news/author/${personSlug}`)}
            class:list={[
              layout === 'institutional'
                ? 'text-[0.8125rem] font-normal text-secondary-3 no-underline decoration-secondary-2/30 underline-offset-2 transition-[text-decoration-color] hover:underline hover:decoration-secondary-2/45'
                : 'text-sm font-medium text-secondary-4 underline decoration-secondary-2/40 underline-offset-2 hover:decoration-secondary-4',
            ]}
          >
            All Intelligence by {personName} →
          </a>
        </p>
      ) : hasMore ? (
        <p class="mt-5">
          <a
            href={localeHref(locale, 'news')}
            class:list={[
              layout === 'institutional'
                ? 'text-[0.8125rem] font-normal text-secondary-3 no-underline decoration-secondary-2/30 underline-offset-2 transition-[text-decoration-color] hover:underline hover:decoration-secondary-2/45'
                : 'text-sm font-medium text-secondary-4 underline decoration-secondary-2/40 underline-offset-2 hover:decoration-secondary-4',
            ]}
          >
            View all Intelligence
          </a>
        </p>
      ) : null}
    </section>
  ) : null
}
