---
import type { Locale } from '../i18n/config';
import type { NewsArticle } from '../data/news';
import NewsEditorialCarousel from '@/components/NewsEditorialCarousel.astro';
import { localeHref } from '../lib/site-nav';

interface Props {
  locale: Locale;
  articles: NewsArticle[];
  /** Max rows to show before “View all news” */
  displayLimit?: number;
  /** Links to `/news/author/{slug}/` (full list of pieces credited to this colleague). */
  personSlug?: string;
  personName?: string;
}

const { locale, articles, displayLimit = 8, personSlug, personName } = Astro.props;
const visible = articles.slice(0, displayLimit);
const hasMore = articles.length > displayLimit;
const showAuthorArchive = Boolean(personSlug?.trim() && personName?.trim());
const excludeAuthorSlugs = personSlug?.trim() ? [personSlug.trim()] : [];
---

{
  articles.length > 0 ? (
    <section class="mt-12 md:mt-14" aria-labelledby="person-news-heading">
      <h2 id="person-news-heading" class="text-sm font-medium uppercase tracking-wide text-secondary-2">
        Related Intelligence
      </h2>
      <p class="mt-2 max-w-2xl text-pretty text-sm leading-relaxed text-secondary-3">
        Published analysis and commentary where this colleague is credited as an author — useful context on perspective and
        public commentary. Co-authors appear on each card with a short role line linking to their profiles.
      </p>
      <div class="mt-6 border-t border-secondary-2/[0.12] pt-5">
        <NewsEditorialCarousel
          {locale}
          articles={visible}
          showTopicBadges={false}
          showAuthorByline={true}
          {excludeAuthorSlugs}
        />
      </div>
      {showAuthorArchive ? (
        <p class="mt-5">
          <a
            href={localeHref(locale, `news/author/${personSlug}`)}
            class="text-sm font-medium text-secondary-4 underline decoration-secondary-2/40 underline-offset-2 hover:decoration-secondary-4"
          >
            All Intelligence by {personName} →
          </a>
        </p>
      ) : hasMore ? (
        <p class="mt-5">
          <a
            href={localeHref(locale, 'news')}
            class="text-sm font-medium text-secondary-4 underline decoration-secondary-2/40 underline-offset-2 hover:decoration-secondary-4"
          >
            View all Intelligence
          </a>
        </p>
      ) : null}
    </section>
  ) : null
}
