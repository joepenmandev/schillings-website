---
import type { Locale } from '@/i18n/config';
import type { NewsArticle } from '@/data/news';
import { newsListAuthorEntries, type NewsListAuthorEntry } from '@/lib/news-list-authors';
import { articleDatePublishedIso } from '@/lib/news-datetime';
import { formatNewsCardDateUk, newsExcerpt, newsHeroAlt, newsHeroDisplaySrc } from '@/lib/news-render';
import { topicSlugFromLabel } from '@/lib/news-topic-slug';
import { localeHref } from '@/lib/site-nav';
import { isHouseNewsAuthorSlug, newsAuthorPublicPathAfterLocale } from '@/data/news-house-author';

interface Props {
  locale: Locale;
  article: NewsArticle;
  /** For image loading priority on listing pages. */
  index?: number;
  showTopicBadges?: boolean;
  showAuthorByline?: boolean;
  excludeAuthorSlugs?: string[];
  /** Outer article classes (carousel vs grid). */
  class?: string;
}

const {
  locale,
  article: a,
  index = 0,
  showTopicBadges = false,
  showAuthorByline = true,
  excludeAuthorSlugs = [],
  class: className = '',
} = Astro.props;

const exclude = new Set((excludeAuthorSlugs ?? []).map((s) => s.trim()).filter(Boolean));

function filterAuthors(entries: NewsListAuthorEntry[]): NewsListAuthorEntry[] {
  if (exclude.size === 0) return entries;
  return entries.filter((e) => e.type === 'credit' || !exclude.has(e.slug));
}

function clipRole(role: string, max = 72): string {
  const t = role.trim();
  if (t.length <= max) return t;
  return `${t.slice(0, max - 1).trimEnd()}…`;
}

const articleHref = localeHref(locale, `news/${a.slug}`);
const rawHero = newsHeroDisplaySrc(a)?.trim();
const heroSrc =
  rawHero && !rawHero.startsWith('http')
    ? rawHero.startsWith('/')
      ? rawHero
      : `/${rawHero}`
    : rawHero;
const heroAlt = newsHeroAlt(a) || a.title;
const cardDate = formatNewsCardDateUk(a);
const rawAuthors = showAuthorByline ? newsListAuthorEntries(a) : [];
const authors = filterAuthors(rawAuthors);
---

<article
  class:list={[
    'flex flex-col overflow-hidden rounded-lg border border-secondary-2/20 bg-brand-white shadow-sm ring-1 ring-secondary-4/[0.06] transition-[box-shadow,transform] duration-300 hover:shadow-lg hover:ring-secondary-2/25',
    className,
  ]}
>
  <a
    href={articleHref}
    class="group/img relative block aspect-square w-full overflow-hidden bg-gradient-to-br from-primary-1/20 to-utility-2"
  >
    <span
      class="absolute inset-0 flex items-center justify-center font-serif text-4xl font-extralight text-secondary-4/25"
      aria-hidden="true"
    >
      {a.title.trim().charAt(0) || '—'}
    </span>
    {
      heroSrc ? (
        <img
          src={heroSrc}
          alt={heroAlt}
          width="400"
          height="400"
          loading={index < 6 ? 'eager' : 'lazy'}
          decoding="async"
          class="relative z-10 h-full w-full object-cover transition-transform duration-500 ease-out group-hover/img:scale-[1.04]"
          onerror="this.remove()"
        />
      ) : null
    }
  </a>
  <div class="flex min-h-[12rem] flex-1 flex-col p-4 sm:p-5">
    <h2 class="font-serif text-[1.15rem] font-normal leading-snug tracking-tight text-secondary-4 sm:text-[1.35rem] sm:leading-[1.2]">
      <a
        href={articleHref}
        class="post-title block text-pretty text-inherit decoration-secondary-2/35 underline-offset-[0.2em] transition-colors hover:text-secondary-3 hover:decoration-secondary-3"
      >
        {a.title}
      </a>
    </h2>

    {
      showTopicBadges && (a.topics?.length ?? 0) > 0 ? (
        <ul class="mt-2 flex flex-wrap gap-1.5" aria-label="Topics">
          {(a.topics ?? []).slice(0, 3).map((t) => (
            <li>
              <a
                href={localeHref(locale, `news/topic/${topicSlugFromLabel(t)}`)}
                class="rounded-full border border-secondary-2/30 bg-utility-2/60 px-2 py-0.5 text-[0.65rem] font-normal text-secondary-3 transition-colors hover:border-secondary-3 hover:bg-utility-2"
              >
                {t}
              </a>
            </li>
          ))}
        </ul>
      ) : null
    }

    {
      authors.length > 0 ? (
        <div class="mt-3 space-y-2.5 border-t border-secondary-2/10 pt-3">
          {authors.map((entry) =>
            entry.type === 'credit' ? (
              <p class="font-serif text-sm italic text-secondary-3">By {entry.name}</p>
            ) : (
              (() => {
                const house = isHouseNewsAuthorSlug(entry.slug);
                const authorHref = localeHref(locale, newsAuthorPublicPathAfterLocale(entry.slug));
                return (
              <div class="flex gap-2.5">
                {entry.imagePath ? (
                  <a
                    href={authorHref}
                    class:list={[
                      'shrink-0 ring-1 ring-secondary-2/20 transition hover:ring-secondary-3',
                      house ? 'rounded-lg bg-brand-white p-0.5' : 'rounded-full',
                    ]}
                    aria-label={house ? `${entry.name} — author archive` : `${entry.name} profile`}
                  >
                    <img
                      src={entry.imagePath}
                      alt=""
                      width="36"
                      height="36"
                      loading="lazy"
                      decoding="async"
                      class="h-9 w-9 rounded-full object-cover"
                    />
                  </a>
                ) : (
                  <span
                    class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-secondary-2/25 bg-utility-2 text-xs font-medium text-secondary-4"
                    aria-hidden="true"
                  >
                    {entry.name
                      .split(/\s+/)
                      .filter(Boolean)
                      .slice(0, 2)
                      .map((w) => w[0]?.toUpperCase() ?? '')
                      .join('')}
                  </span>
                )}
                <div class="min-w-0 flex-1">
                  <p class="font-serif text-sm italic leading-tight text-secondary-4">
                    <span class="not-italic font-sans text-xs font-normal text-secondary-2">By </span>
                    <a
                      href={authorHref}
                      class="underline decoration-secondary-2/40 underline-offset-2 transition-colors hover:text-secondary-3 hover:decoration-secondary-3"
                    >
                      {entry.name}
                    </a>
                  </p>
                  {entry.role ? (
                    <p class="mt-0.5 text-xs leading-snug text-secondary-3 line-clamp-2">{clipRole(entry.role)}</p>
                  ) : null}
                </div>
              </div>
                );
              })(),
            ),
          )}
        </div>
      ) : null
    }

    <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-secondary-3">{newsExcerpt(a, 120)}</p>

    <div class="mt-auto flex flex-wrap items-end justify-between gap-2 border-t border-secondary-2/15 pt-4">
      {
        cardDate ? (
          <time class="text-xs tabular-nums tracking-wide text-secondary-2" datetime={articleDatePublishedIso(a)}>
            {cardDate}
          </time>
        ) : (
          <span class="text-xs text-secondary-2"> </span>
        )
      }
      <a
        href={articleHref}
        class="inline-flex shrink-0 items-center gap-1.5 rounded-sm bg-secondary-4 px-3 py-2 text-xs font-medium tracking-wide text-brand-white transition hover:bg-secondary-3 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary-4"
      >
        Read more
        <span aria-hidden="true" class="text-sm leading-none">
          ↗
        </span>
      </a>
    </div>
  </div>
</article>
