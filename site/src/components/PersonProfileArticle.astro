---
/**
 * Bio layout: default (migration parity) vs institutional benchmark (`jenny-afia` only until approved for roll-out).
 */
import PersonTrustSignals from '@/components/PersonTrustSignals.astro';
import PersonPublicContact from '@/components/PersonPublicContact.astro';
import PersonProfileContextSections from '@/components/PersonProfileContextSections.astro';
import PersonRelatedAndExplore from '@/components/PersonRelatedAndExplore.astro';
import SectionKicker from '@/components/SectionKicker.astro';
import PersonContactCta from '@/components/PersonContactCta.astro';
import PersonNewsByline from '@/components/PersonNewsByline.astro';
import PersonInstitutionalStanding from '@/components/PersonInstitutionalStanding.astro';
import type { NewsArticle } from '@/data/news';
import type { PersonProfile } from '@/data/people';
import { EXPERTISE_LABELS } from '@/data/people-taxonomy';
import { expertisePathSlug } from '@/lib/expertise-paths';
import { EXPERTISE_PUBLIC_SEGMENT, localeHref } from '@/lib/site-nav';
import type { Locale } from '@/i18n/config';
import { PEOPLE_PROFILE_H1_CLASS } from '@/lib/visual-tokens';

interface Props {
  locale: Locale;
  person: PersonProfile;
  profileSubline: string;
  localeBioNote: string | null;
  isThinProfile: boolean;
  newsByPerson: NewsArticle[];
}

const { locale, person, profileSubline, localeBioNote, isThinProfile, newsByPerson } = Astro.props;

const institutional = person.slug === 'jenny-afia' && !isThinProfile;
const recognitions = person.recognitions ?? [];
---

{
  institutional ? (
    <div id="person-evaluation-surface" class="mt-7 overflow-x-clip md:mt-8">
      <header class="max-w-[38rem]">
        <h1 class:list={[PEOPLE_PROFILE_H1_CLASS]}>{person.name}</h1>
        <p class="mt-3 max-w-[32rem] text-pretty font-serif text-lg font-extralight italic leading-snug text-secondary-3 md:text-[1.35rem] md:leading-[1.35]">
          {profileSubline}
        </p>
        {localeBioNote ? (
          <p class="mt-4 max-w-[28rem] text-pretty text-[0.8125rem] font-extralight leading-relaxed text-secondary-2/88">{localeBioNote}</p>
        ) : null}
      </header>

      <div class="mt-7 grid grid-cols-1 gap-y-5 min-[520px]:grid-cols-12 min-[520px]:gap-x-5 min-[520px]:gap-y-0 min-[520px]:items-start lg:mt-8 lg:gap-x-0">
        <div class="min-w-0 min-[520px]:col-span-7 min-[520px]:row-start-1 lg:col-span-5 lg:col-start-1 lg:row-start-1 lg:max-w-[30rem] lg:pr-5 xl:pr-9">
          <PersonInstitutionalStanding recognitions={recognitions} personName={person.name} />
        </div>
        {person.imagePath ? (
          <div class="min-w-0 min-[520px]:col-span-5 min-[520px]:row-start-1 lg:col-span-8 lg:col-start-5 lg:row-span-2 lg:row-start-1 lg:-mt-1">
            <div class="relative mx-auto w-full max-w-[16.5rem] min-[520px]:mx-0 min-[520px]:max-w-none lg:ml-0 lg:mr-[max(-0.5rem,-1.2vw)] lg:max-w-[min(25.5rem,calc(100%+1.75rem))]">
              <div class="lg:-translate-y-1 lg:translate-x-[min(0.75rem,2vw)] xl:translate-x-[min(1.25rem,3vw)]">
                <div class="lg:sticky lg:top-20">
                  <div class="relative aspect-[3/4] w-full min-h-[18rem] overflow-hidden shadow-[0_1px_0_0_rgba(0,0,0,0.04)] min-[520px]:min-h-[19.5rem] lg:aspect-auto lg:h-[min(32.5rem,calc(100vh-8rem))] lg:min-h-[24rem] lg:max-h-[34rem]">
                    <img
                      src={person.imagePath}
                      alt={person.name}
                      width={640}
                      height={800}
                      class="absolute inset-0 h-full w-full object-cover object-[27%_10%] [transform-origin:30%_18%] scale-[1.17]"
                      sizes="(max-width: 1024px) 45vw, 380px"
                      loading="eager"
                      decoding="async"
                      fetchpriority="high"
                    />
                  </div>
                </div>
              </div>
            </div>
          </div>
        ) : null}
        <div class="min-w-0 border-t border-secondary-2/[0.045] pt-4 min-[520px]:col-span-12 min-[520px]:border-secondary-2/[0.04] min-[520px]:pt-5 lg:col-span-5 lg:col-start-1 lg:row-start-2 xl:max-w-[30rem]">
          <PersonTrustSignals
            personName={person.name}
            sameAs={person.sameAs ?? []}
            recognitions={recognitions}
            hideLinkedIn
            hideRecognitionBadges
            complianceTone="quiet"
            surface="plain"
            omitIntro
            directoryStyle="index"
            flush
          />
        </div>
      </div>

      <div class="min-w-0 lg:max-w-[min(100%,44rem)]">
        <div class="mt-12 md:mt-14 lg:mt-16">
          <PersonProfileContextSections locale={locale} person={person} layout="institutional" />
        </div>
        <div class="mt-10 md:mt-12 lg:mt-14 lg:max-w-[36rem]">
          <PersonPublicContact slug={person.slug} sameAs={person.sameAs ?? []} tone="admin" />
        </div>
        <section class="mt-12 max-w-[34rem] md:mt-12 lg:mt-14 xl:mt-[4.25rem]" aria-labelledby="person-bio-heading">
          <SectionKicker id="person-bio-heading" tone="quiet">Biography</SectionKicker>
          <div class="mt-4 space-y-7 text-pretty text-[0.9rem] font-extralight leading-[1.72] text-secondary-3/[0.9] md:mt-5 md:space-y-8 md:text-[0.925rem]">
            {person.paragraphs.map((para, idx) => (
              <p class:list={[idx === 0 ? 'text-secondary-3/[0.88]' : '']}>{para}</p>
            ))}
          </div>
        </section>
      </div>
      <PersonContactCta locale={locale} personName={person.name} tone="quiet" />
      <PersonNewsByline
        locale={locale}
        articles={newsByPerson}
        personSlug={person.slug}
        personName={person.name}
        layout="institutional"
      />
    </div>
  ) : (
    <>
      <div
        class:list={[
          'mt-6 grid max-w-6xl grid-cols-1 gap-y-8 md:mt-8 lg:items-start lg:gap-y-8',
          person.imagePath ? 'lg:grid-cols-[minmax(0,1fr)_auto] lg:gap-x-12 xl:gap-x-16' : 'lg:grid-cols-1',
        ]}
      >
        <header class="min-w-0 lg:col-start-1 lg:row-start-1">
          <h1 class={PEOPLE_PROFILE_H1_CLASS}>{person.name}</h1>
          <p class="mt-2 max-w-3xl text-pretty font-serif text-xl font-extralight italic leading-snug text-secondary-4 md:text-2xl md:leading-snug">
            {profileSubline}
          </p>
          {localeBioNote ? (
            <p class="mt-4 max-w-2xl text-pretty text-sm leading-relaxed text-secondary-3">{localeBioNote}</p>
          ) : null}
          {isThinProfile && person.expertise && person.expertise.length > 0 ? (
            <ul class="mt-6 flex flex-wrap gap-2" aria-label="Expertise">
              {person.expertise.map((id) => (
                <li>
                  <a
                    href={localeHref(locale, `${EXPERTISE_PUBLIC_SEGMENT}/${expertisePathSlug(id)}`)}
                    class="inline-block rounded-full border border-secondary-2/40 px-3 py-1 text-xs font-normal text-secondary-3 transition-colors hover:border-secondary-3 hover:bg-utility-2/60"
                  >
                    {EXPERTISE_LABELS[id]}
                  </a>
                </li>
              ))}
            </ul>
          ) : null}
        </header>
        {person.imagePath ? (
          <div class="mx-auto w-full max-w-[20rem] shrink-0 lg:col-start-2 lg:row-start-1 lg:row-span-2 lg:mx-0 lg:flex lg:justify-end lg:self-start">
            <div class="overflow-hidden rounded-sm shadow-md ring-1 ring-secondary-2/20 lg:sticky lg:top-28">
              <img
                src={person.imagePath}
                alt={person.name}
                width={480}
                height={480}
                class="aspect-square w-full object-cover"
                sizes="(max-width: 1024px) 100vw, 320px"
                loading="eager"
                decoding="async"
                fetchpriority="high"
              />
            </div>
          </div>
        ) : null}
        <section
          class:list={['max-w-[52rem]', person.imagePath ? 'lg:col-start-1 lg:row-start-2' : '']}
          aria-labelledby="person-bio-heading"
        >
          <SectionKicker id="person-bio-heading">Biography</SectionKicker>
          <div class="mt-5 space-y-5 text-pretty text-base font-normal leading-[1.65] text-secondary-3 md:mt-6 md:space-y-6 md:text-[1.05rem]">
            {person.paragraphs.map((para) => (
              <p>{para}</p>
            ))}
          </div>
        </section>
      </div>
      {isThinProfile ? null : <PersonProfileContextSections locale={locale} person={person} />}
      <PersonPublicContact slug={person.slug} sameAs={person.sameAs ?? []} />
      <PersonNewsByline locale={locale} articles={newsByPerson} personSlug={person.slug} personName={person.name} />
      <PersonTrustSignals personName={person.name} sameAs={person.sameAs ?? []} recognitions={recognitions} hideLinkedIn />
      <PersonContactCta locale={locale} personName={person.name} />
      <PersonRelatedAndExplore locale={locale} />
    </>
  )
}
