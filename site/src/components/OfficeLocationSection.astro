---
import type { Locale } from '../i18n/config';
import type { Office } from '../lib/offices';
import { localeHref } from '../lib/site-nav';
import QualifyingForm from './QualifyingForm.astro';
import OfficeMapFrame from './OfficeMapFrame.astro';
import OfficeTeamPreview from './OfficeTeamPreview.astro';

interface Props {
  locale: Locale;
  office: Office;
}

const { locale, office } = Astro.props;
---

<div class="space-y-10">
  <header class="max-w-3xl">
    <p class="text-xs font-medium uppercase tracking-[0.18em] text-secondary-2">Schillings office</p>
    <h1 class="mt-2 text-3xl font-extralight leading-tight tracking-tight text-secondary-4 md:text-[3.125rem] md:leading-[1.1]">
      {office.name}
    </h1>
    <p class="mt-3 text-pretty text-secondary-3">
      Address, map, and phone below. Use the enquiry form to reach the team — the <strong class="font-normal text-secondary-4">region</strong> step
      matches this office by default and can be changed if needed.
    </p>
  </header>

  <div class="grid gap-12 lg:grid-cols-2 lg:gap-14 lg:items-start">
    <div class="space-y-8">
      <section class="rounded-lg border border-secondary-2/20 bg-utility-2/50 p-6 md:p-8" aria-labelledby={`office-addr-${office.slug}`}>
        <h2 id={`office-addr-${office.slug}`} class="text-sm font-semibold uppercase tracking-wide text-secondary-2">
          Address
        </h2>
        <address class="mt-3 not-italic text-pretty font-serif text-lg leading-relaxed text-secondary-4">
          {office.addressLines.map((line) => (
            <span class="block">{line}</span>
          ))}
        </address>
        <div class="mt-6 space-y-2 text-secondary-4">
          <p>
            <span class="text-sm font-medium text-secondary-3">Phone</span>
            <br />
            <a class="font-medium underline decoration-secondary-2/50 underline-offset-2 hover:text-secondary-3" href={office.phoneHref}>
              {office.phoneDisplay}
            </a>
          </p>
          <p>
            <span class="text-sm font-medium text-secondary-3">Email</span>
            <br />
            <a
              class="break-all font-medium underline decoration-secondary-2/50 underline-offset-2 hover:text-secondary-3"
              href={`mailto:${office.email}`}
            >
              {office.email}
            </a>
          </p>
        </div>
      </section>

      <section aria-labelledby={`office-map-${office.slug}`}>
        <h2 id={`office-map-${office.slug}`} class="sr-only">
          Map
        </h2>
        <OfficeMapFrame
          title={office.mapIframeTitle}
          mapId={office.slug}
          lat={office.mapLat}
          lng={office.mapLng}
          zoom={office.mapZoom}
        />
      </section>

      <p class="text-sm text-secondary-3">
        <a href={localeHref(locale, 'international')} class="font-medium text-secondary-4 underline hover:text-secondary-3">
          All offices &amp; international
        </a>
        <span class="mx-2 text-secondary-2" aria-hidden="true">
          ·
        </span>
        <a href={localeHref(locale, 'contact')} class="font-medium text-secondary-4 underline hover:text-secondary-3">
          General contact
        </a>
      </p>
    </div>

    <div class="lg:pt-1">
      <h2 class="text-lg font-semibold text-secondary-4">Enquiry form</h2>
      <p class="mt-2 text-pretty text-sm text-secondary-3">
        Same qualifying flow as the main contact page. Step 2 (region) defaults to this office’s jurisdiction.
      </p>
      <div class="mt-6">
        <QualifyingForm
          locale={locale}
          defaultRegion={office.formRegion}
          preferredOffice={office.slug}
          regionPresetReason="office"
        />
      </div>
    </div>
  </div>

  <OfficeTeamPreview {locale} {office} />
</div>
